<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 高度由 setHeightRatio 在 onMeasure 里按真实宽算(对齐瀑布流 recy_illust_stagger):
             ratio 已知(P1 靠 IllustsBean、多 P 靠网页 ajax、兜底靠解码位图)→ 首帧就量在终值,
             不再有「兜底高→自然高」的跳。ratio 未设(=0)时退回下面的 240dp 占位高。 -->
        <ceui.lisa.view.DynamicHeightImageView
            android:id="@+id/illust"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@color/loading_placeholder"
            android:scaleType="fitCenter" />

        <!-- 顶层原图 overlay：底层 illust 先秒显 large(命中瀑布流缓存),原图下好后加载进这一层、
             淡入盖住 large。底层 large 全程不被清 → 大图换原图零闪烁。四边对齐 illust 精确覆盖。
             与底层同为 DynamicHeightImageView:贴图前用「只读宽高」读出原图真尺寸,先把 ratio 同步到
             底层 illust + 本层,再淡入 → 展示盒即原图真比,crossfade 盖上零 letterbox。 -->
        <ceui.lisa.view.DynamicHeightImageView
            android:id="@+id/illust_hd"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignTop="@+id/illust"
            android:layout_alignBottom="@+id/illust"
            android:layout_alignStart="@+id/illust"
            android:layout_alignEnd="@+id/illust"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <!-- 多 P 页与页之间的分割线:上下留白 + 一条主题自适应细线,让堆叠的整幅大图看得出边界。
             留白透出 feed 的 v3_bg,与页面的 loading_placeholder 底有色差;细线再明确一下界限。
             单 P / 末页也会带一条,读作「图 → 资料区」的分隔,无害。 -->
        <View
            android:id="@+id/page_divider"
            android:layout_width="match_parent"
            android:layout_height="@dimen/hair_line_width"
            android:layout_below="@id/illust"
            android:background="@color/divider_color" />

        <include
            android:id="@+id/progress_layout"
            layout="@layout/item_progress" />

        <Button
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:visibility="gone"
            android:id="@+id/reload"
            android:layout_centerInParent="true"
            android:text="@string/string_73">

        </Button>

        <!-- V3 only: bottom-scrim + glass pill for the "展开剩余 X 张" CTA.
             CollapsibleIllustAdapter toggles visibility on pos-0 when collapsed. -->
        <FrameLayout
            android:id="@+id/expand_overlay"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="@drawable/bg_v3_first_page_scrim"
            android:layout_alignBottom="@+id/illust"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/expand_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_v3_expand_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="9dp">

                    <ImageView
                        android:id="@+id/expand_chevron"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_collections_black_24dp"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/expand_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.02"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/comic_reader_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_v3_expand_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="9dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_baseline_menu_book_24"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.02"
                        android:text="@string/comic_reader_enter"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </RelativeLayout>


</layout>
