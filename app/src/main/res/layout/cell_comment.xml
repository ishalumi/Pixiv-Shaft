<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="ceui.pixiv.ui.comments.CommentHolder" />
        <import type="ceui.pixiv.session.SessionManager" />

        <variable
            name="holder"
            type="CommentHolder" />
    </data>

    <!-- 间距交给 RecyclerView 的 LinearItemDecoration(见 PixivFragment VERTICAL_COMMENT),
         不在 cell 上挂 margin,否则首个 cell 距顶部太近 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="@drawable/v3_ripple_card22"
        app:cardBackgroundColor="@color/v3_glass_card"
        app:cardCornerRadius="22dp"
        app:cardElevation="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <!-- ═══ Header: avatar · [作者] name · time ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/user_icon"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="12dp"
                    android:scaleType="centerCrop"
                    app:civ_border_color="@color/v3_border_2"
                    app:civ_border_width="2dp"
                    userIcon="@{holder.comment.user}" />

                <TextView
                    android:id="@+id/arthur_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="7dp"
                    android:background="@drawable/v3_author_badge_bg"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.02"
                    android:paddingStart="7dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="7dp"
                    android:paddingBottom="2dp"
                    android:text="@string/string_432"
                    android:textColor="@color/v3_purple"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="作者"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/user_name"
                    style="@style/textMontserratSemiBold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:letterSpacing="-0.01"
                    android:maxLines="1"
                    android:text="@{holder.comment.user.name}"
                    android:textColor="@color/v3_text_1"
                    android:textSize="15sp"
                    tools:text="Pixiv 用户的名字很长很长" />

                <TextView
                    android:id="@+id/comment_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:letterSpacing="0.02"
                    android:maxLines="1"
                    android:textColor="@color/v3_text_3"
                    android:textSize="11sp"
                    tools:text="3 小时前" />
            </LinearLayout>

            <!-- ═══ Body: text or stamp ═══ -->
            <FrameLayout
                android:id="@+id/content_frame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="54dp"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/comment_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.01"
                    android:lineSpacingMultiplier="1.35"
                    android:textColor="@color/v3_text_1"
                    android:textSize="15sp"
                    tools:text="这是一条评论内容，写得挺长的一段话用来测试换行和行距效果。" />

                <net.csdn.roundview.RoundImageView
                    android:id="@+id/comment_stamp"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    app:rRadius="18dp" />
            </FrameLayout>

            <!-- ═══ Actions ═══ -->
            <LinearLayout
                android:id="@+id/action_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="54dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/reply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/v3_action_pill_bg"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/string_176"
                    android:textColor="@color/v3_text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    visibleOrGone="@{SessionManager.INSTANCE.loggedInUid != holder.comment.user.id}" />

                <ceui.loxia.ProgressTextButton
                    android:id="@+id/show_reply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/v3_action_pill_bg"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/show_reply"
                    android:textAllCaps="false"
                    android:textColor="@color/v3_text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:ptb_progress_stroke_width="3dp"
                    app:ptb_progress_width="14dp" />

                <ceui.loxia.ProgressTextButton
                    android:id="@+id/delete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/v3_action_pill_bg"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/string_219"
                    android:textAllCaps="false"
                    android:textColor="@color/v3_danger"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:ptb_progress_stroke_width="3dp"
                    app:ptb_progress_width="14dp"
                    visibleOrGone="@{SessionManager.INSTANCE.loggedInUid == holder.comment.user.id}" />
            </LinearLayout>

            <!-- ═══ Nested reply thread ═══ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/child_comments_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/v3_comment_thread_bg"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</layout>
