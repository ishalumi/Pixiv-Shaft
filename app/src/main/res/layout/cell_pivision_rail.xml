<?xml version="1.0" encoding="utf-8"?>
<!--
  发现页「pixivision 特辑」横向货架卡 (MD3-Expressive / V3),与竖版 cell_pivision 同一套语言、
  缩到货架尺寸。整卡就是一张图:封面铺满 + 底部渐变遮罩压住标题,分类 tonal 胶囊悬左上。

  用普通 FrameLayout(不用 MaterialCardView / QMUIRoundRelativeLayout):圆角由 Renderer 注入
  V3Palette.settingsCardBg + clipToOutline 裁图,和 V3 其它卡同款,日夜双模跟随主题色。
  卡尺寸 220x160dp 与 R.dimen.article_horizontal_height 一致(货架高度按它算)。
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_root"
    android:layout_width="220dp"
    android:layout_height="160dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:stateListAnimator="@animator/button_press_scale">

    <ImageView
        android:id="@+id/cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/light_bg"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <View
        android:id="@+id/cover_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_request_cover_scrim" />

    <!-- 分类胶囊(subcategory_label,底色在代码里注入;没有该字段时 gone) -->
    <TextView
        android:id="@+id/category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|top"
        android:layout_margin="10dp"
        android:fontFamily="@font/montserrat_semi_bold"
        android:letterSpacing="0.02"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textSize="10.5sp"
        android:visibility="gone"
        tools:text="Manga"
        tools:visibility="visible" />

    <!-- 标题压在封面底部 -->
    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="start|bottom"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="10dp"
        android:ellipsize="end"
        android:fontFamily="@font/montserrat_bold"
        android:maxLines="2"
        android:shadowColor="#B3000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="6"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        tools:text="夏天的风、光与影 —— 精选插画特辑" />
</FrameLayout>
