<?xml version="1.0" encoding="utf-8"?>
<!--
  举报第一步的单条违规类型行，服务端 topic-list 动态下发，条数不固定，所以运行时用
  LayoutInflater 逐条 inflate 进容器，而不是写死几条 XML。背景（top/mid/bottom/single）
  按运行时位置在代码里挂 bg_m3_row_*。
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/topic_row_root"
    style="@style/M3SetRow">

    <LinearLayout style="@style/M3SetTexts">

        <TextView
            android:id="@+id/topic_title"
            style="@style/M3SetTitle" />
    </LinearLayout>

    <TextView style="@style/M3SetArrow" />

</RelativeLayout>
