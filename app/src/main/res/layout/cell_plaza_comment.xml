<?xml version="1.0" encoding="utf-8"?>
<!-- 单条评论。Figma 风 (0:21287/0:21320):
     - 头像 36dp 左
     - 顶行:用户名 14sp Semibold 左 + 时间 10sp 右 + 「作者」标(post 作者才有)
     - 正文 13sp,正文行高比 v3_text_2 略亮
     - 帖间靠 0.5dp 底分隔线区分,不靠 padding -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:paddingStart="18dp"
    android:paddingTop="14dp"
    android:paddingEnd="18dp"
    android:paddingBottom="14dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@mipmap/ic_launcher" />

    <!-- 时间右侧。固定 wrap_content,name 用 0dp 拉伸顶住时间左侧。 -->
    <TextView
        android:id="@+id/post_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0.6"
        android:textColor="@color/v3_text_2"
        android:textSize="10sp"
        app:layout_constraintBaseline_toBaselineOf="@+id/display_name"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="12 min ago" />

    <!-- 「作者」标:仅当评论作者 = 帖子作者时显示。 -->
    <TextView
        android:id="@+id/author_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_v3_chip"
        android:paddingStart="6dp"
        android:paddingTop="1dp"
        android:paddingEnd="6dp"
        android:paddingBottom="1dp"
        android:text="@string/plaza_author_tag"
        android:textColor="@color/v3_text_2"
        android:textSize="10sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/display_name"
        app:layout_constraintStart_toEndOf="@+id/avatar"
        app:layout_constraintTop_toTopOf="@+id/display_name"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/display_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/v3_text_1"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@+id/post_time"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@+id/author_tag"
        app:layout_constraintTop_toTopOf="@+id/avatar"
        tools:text="Carl Richard" />

    <TextView
        android:id="@+id/body_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/v3_text_1"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/avatar"
        app:layout_constraintTop_toBottomOf="@+id/display_name"
        tools:text="You do not have to pretend in order to seem more like someone else." />

</androidx.constraintlayout.widget.ConstraintLayout>
