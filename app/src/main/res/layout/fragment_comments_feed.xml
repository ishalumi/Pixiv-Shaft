<?xml version="1.0" encoding="utf-8"?>
<!--
  评论页(feeds 框架版)骨架:toolbar(标准 fragment_toolbar_feed 5 件套,对齐
  HotTagsFeedFragment/RecmdMangaFeedFragment 等其余 feeds 页——本页背景已是纯色
  v3_bg,不再浮在模糊图上,不该用 layout_toolbar 那套透明浮动 toolbar)
  + feed_root(标准 feeds 列表) + 底部 MD3-E 输入栏。
  输入栏刻意不用 MaterialButton/TextInputLayout(AppCompat host 缺 Material3 attrs 会崩,见
  feedback_pixivshaft_textview_inflate),改用 V3Palette 在代码里现算圆角胶囊 + 填充色
  发送按钮,和全仓其余「MD3-E」页面(设置/阅读器 sheet)同一套纯 XML + 运行时着色打法。
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/six_dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:title=" "
        app:titleTextColor="@android:color/white">

        <TextView
            android:id="@+id/toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="18sp" />

    </androidx.appcompat.widget.Toolbar>

    <include
        android:id="@+id/feed_root"
        layout="@layout/fragment_feed"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 「回复 @xxx」提示条:回复目标可见 + 可一键取消,替代旧版只靠 EditText hint 隐晦提示 -->
        <LinearLayout
            android:id="@+id/reply_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="10dp"
            android:paddingEnd="10dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/reply_banner_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/v3_text_2"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="回复 @某某用户" />

            <ImageView
                android:id="@+id/reply_banner_close"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cancel"
                android:padding="5dp"
                android:src="@drawable/ic_close_black_24dp"
                app:tint="@color/v3_text_3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/emoji_toggle"
                android:layout_width="40dp"
                android:layout_height="44dp"
                android:layout_gravity="bottom"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/comment_emoji_picker"
                android:padding="9dp"
                android:src="@drawable/chat_ic_emoji"
                app:tint="@color/v3_text_3" />

            <EditText
                android:id="@+id/comment_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:background="@android:color/transparent"
                android:hint="@string/string_49"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="4"
                android:minHeight="46dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="11dp"
                android:textColor="@color/v3_text_1"
                android:textColorHint="@color/v3_text_3"
                android:textSize="15sp" />

            <ceui.loxia.ProgressImageButton
                android:id="@+id/send_button"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="bottom"
                android:background="@android:color/transparent"
                android:contentDescription="@string/plaza_send"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/chat_ic_send"
                app:tint="@color/always_white" />
        </LinearLayout>

        <!-- 「绘文字」(38 个 pixiv 内置文字表情)/「表情贴图」(官方常驻 40 个插画贴纸)双 tab
             面板:点绘文字插入输入框光标处,点贴纸直接单发一条纯贴纸评论;两页装在 ViewPager2
             里,点 tab 或左右滑动都能切页。面板整体作为 BottomPanelCoordinator 的 panelView,
             跟系统键盘严格互斥 + 等高过渡,不再是这里自己手写的 insets Listener(见 setUpEmojiPanel)。
             XML 高度只是首帧占位,展示前会被 coordinator 按实测键盘高度覆盖。 -->
        <LinearLayout
            android:id="@+id/emoji_panel_container"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@color/v3_surface_2"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tab_kaomoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="@string/comment_emoji_tab_kaomoji"
                    android:textColor="@color/v3_text_1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_stamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="@string/comment_emoji_tab_stamp"
                    android:textColor="@color/v3_text_2"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/emoji_pager"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
