<?xml version="1.0" encoding="utf-8"?>
<!-- 「其他条件」子 sheet：屏蔽 AI 开关 + 插画/漫画专属（制图工具）+ 小说专属（仅限原创 /
     仅限单词置换）+ R-18 三选一。各 mode-specific 卡片的可见性由 [OtherFilterSheet] 按
     isNovel 切；对应不适用的 mode 整张卡片隐藏。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_v3_sheet_top"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="start|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/search_filter_v3_cancel"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/search_filter_v3_row_other"
            android:textColor="@color/v3_text_1"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/search_filter_v3_confirm"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AI section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_v3_settings_card"
                android:clipToOutline="true"
                android:orientation="vertical">

                <include
                    android:id="@+id/row_ai"
                    layout="@layout/cell_search_filter_switch_row" />
            </LinearLayout>

            <!-- 插画/漫画专属（制图工具）—— novel 模式整张卡片 GONE -->
            <Space
                android:id="@+id/illust_tool_space"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/illust_tool_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_v3_settings_card"
                android:clipToOutline="true"
                android:orientation="vertical"
                android:visibility="gone">

                <include
                    android:id="@+id/row_tool"
                    layout="@layout/cell_search_filter_row" />
            </LinearLayout>

            <!-- 小说专属（仅限原创 / 仅限支持单词置换）—— illust 模式整张卡片 GONE -->
            <Space
                android:id="@+id/novel_section_space"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/novel_section_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_v3_settings_card"
                android:clipToOutline="true"
                android:orientation="vertical"
                android:visibility="gone">

                <include
                    android:id="@+id/row_original_only"
                    layout="@layout/cell_search_filter_switch_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_replaceable_only"
                    layout="@layout/cell_search_filter_switch_row" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp" />

            <!-- R-18 section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_v3_settings_card"
                android:clipToOutline="true"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="10dp"
                    android:text="@string/search_filter_v3_section_r18"
                    android:textColor="@color/v3_text_2"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_r18_all"
                    layout="@layout/cell_search_filter_check_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_r18_safe"
                    layout="@layout/cell_search_filter_check_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_r18_only"
                    layout="@layout/cell_search_filter_check_row" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
