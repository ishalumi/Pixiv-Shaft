<?xml version="1.0" encoding="utf-8"?>
<!-- 单条 plaza 帖子。Figma 风:平铺(无 CardView),卡片间用 divider 分隔,
     v3 token 自动适配 day/night。
     - header (头像 / 名字 / 认证 / 时间 / 更多)
     - body (正文 15sp)
     - refs.illust 走 LinearLayout 容器,bindIllustGrid 按数量动态拼布局
     - refs.user 走横向 chip 行,只在有 user ref 时显示
     - 底部 0.5dp divider 把帖子隔开 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:orientation="vertical">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="8dp"
        android:paddingBottom="10dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@mipmap/ic_launcher" />

        <!-- name 跟 verified 用 packed chain 紧贴,跟 figma 一致 -->
        <TextView
            android:id="@+id/display_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/v3_text_1"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@+id/post_time"
            app:layout_constraintEnd_toStartOf="@+id/verified_mark"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@+id/avatar"
            app:layout_constraintTop_toTopOf="@+id/avatar"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="桐井" />

        <!-- 认证小标:数据有就 setVisible(true),figma 上是绿圈打钩 -->
        <ImageView
            android:id="@+id/verified_mark"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_verified_check"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/display_name"
            app:layout_constraintEnd_toStartOf="@+id/more_btn"
            app:layout_constraintStart_toEndOf="@+id/display_name"
            app:layout_constraintTop_toTopOf="@+id/display_name"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/post_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/v3_text_2"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@+id/avatar"
            app:layout_constraintEnd_toStartOf="@+id/more_btn"
            app:layout_constraintStart_toEndOf="@+id/avatar"
            app:layout_constraintTop_toBottomOf="@+id/display_name"
            tools:text="A moment ago" />

        <ImageButton
            android:id="@+id/more_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/plaza_more_menu"
            android:src="@drawable/ic_more_vert_black_24dp"
            app:layout_constraintBottom_toBottomOf="@+id/avatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/avatar"
            app:tint="@color/v3_text_2" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 正文 -->
    <TextView
        android:id="@+id/body_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:autoLink="web"
        android:lineSpacingExtra="3dp"
        android:linksClickable="true"
        android:paddingStart="18dp"
        android:paddingTop="0dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp"
        android:textColor="@color/v3_text_1"
        android:textColorLink="?attr/colorPrimary"
        android:textSize="15sp"
        tools:text="You do not have to pretend in order to seem more like someone else." />

    <!-- 引用 illust 容器。子 view 由 bindIllustGrid 按数量构造。 -->
    <LinearLayout
        android:id="@+id/illust_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="12dp"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- 引用 user 行。只在有 user refs 时显示。 -->
    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/user_refs_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="18dp"
        android:paddingTop="0dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        app:flexWrap="wrap"
        tools:visibility="visible" />

    <!-- 互动 chips:like / comment 计数。点击跟整张卡片一样进详情页(详情页里
         统一处理 toggle like),feed 里 chip 只展示数字。 -->
    <LinearLayout
        android:id="@+id/action_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/like_chip"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:background="@drawable/bg_v3_chip"
            android:gravity="center_vertical"
            android:minWidth="50dp"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/like_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_heart_outline_16"
                app:tint="@color/v3_text_2"
                tools:src="@drawable/ic_heart_filled_16" />

            <TextView
                android:id="@+id/like_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/v3_text_1"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="69" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/comment_chip"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_v3_chip"
            android:gravity="center_vertical"
            android:minWidth="50dp"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_comment_outline_16"
                app:tint="@color/v3_text_2" />

            <TextView
                android:id="@+id/comment_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/v3_text_1"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="2,251" />
        </LinearLayout>

    </LinearLayout>

    <!-- 帖间 divider。0.5dp 太细在某些屏会消失,用 1px 实际 ≈ 0.34dp,
         足够薄又稳定可见。 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="@color/v3_border_1" />

</LinearLayout>
