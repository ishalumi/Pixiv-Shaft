<?xml version="1.0" encoding="utf-8"?>
<!--
  feeds 框架独立页骨架:Toolbar 抄 fragment_webview 5 件套(AppBarOverlay + popupTheme +
  navigationIcon + titleTextColor + title 占位居中 TextView),状态栏 inset 走 BarUtils
  在代码里 padding,不用 fitsSystemWindows(BaseActivity 开了 EdgeToEdge,会重复套 inset)。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/six_dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:title=" "
        app:titleTextColor="@android:color/white">

        <!--
          标题 + 可选副标题(计数等)。副标题默认 GONE:本布局被所有 feeds 独立页共用,
          不设的页面维持原来的单行居中标题,不受影响。
        -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/toolbar_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.75"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="1–26 of 2000"
                tools:visibility="visible" />

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <include
        android:id="@+id/feed_root"
        layout="@layout/fragment_feed"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
