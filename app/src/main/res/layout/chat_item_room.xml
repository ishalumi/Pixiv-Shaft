<?xml version="1.0" encoding="utf-8"?>
<!-- Conversation row, adapted from Figma 3201:18622 / 3201:18642.
     Figma proportions: 50dp avatar, 14dp gap, vertical content column
     with title+time on row 1 and preview+unread badge on row 2.
     Per-row 1dp bottom divider drawn via foreground (so background
     `selectableItemBackground` still rides on top). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:foreground="@drawable/chat_room_row_divider"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_avatar"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:scaleType="centerCrop"
        android:src="@drawable/chat_avatar_placeholder"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Chat.Avatar" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="匿名_104522745" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:includeFontPadding="false"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="2h" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_preview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                tools:text="哈哈哈哈" />

            <!-- Unread badge: a rounded red pill with the count.
                 Single-digit shows centered; 2+ digits grow horizontally
                 thanks to wrap_content + horizontal padding.
                 Visible only when unread_count > 0. -->
            <TextView
                android:id="@+id/tv_unread"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/chat_room_unread_badge"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="18dp"
                android:paddingHorizontal="6dp"
                android:textColor="@color/always_white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="2"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
