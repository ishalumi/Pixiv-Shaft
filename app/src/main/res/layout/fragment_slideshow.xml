<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/slideshow_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:clipChildren="true">

    <ImageView
        android:id="@+id/slide_image_a"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/slide_image_b"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0"
        android:contentDescription="@null" />

    <FrameLayout
        android:id="@+id/slide_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"
        android:background="#80000000">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:indeterminateTint="@android:color/white" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/slide_controls"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="top"
            android:background="@drawable/black_gradient_revert" />

        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_gravity="bottom"
            android:background="@drawable/black_gradient" />

        <LinearLayout
            android:id="@+id/slide_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/slide_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/baseline_arrow_back_24"
                app:tint="@android:color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/slide_indicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="3 / 30" />

            <ImageView
                android:id="@+id/slide_pause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_baseline_pause_24"
                app:tint="@android:color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/slide_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <ImageView
                android:id="@+id/slide_prev"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:padding="14dp"
                android:src="@drawable/ic_reader_prev_chapter"
                app:tint="@android:color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null" />

            <Space
                android:layout_width="40dp"
                android:layout_height="0dp" />

            <ImageView
                android:id="@+id/slide_next"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:padding="14dp"
                android:src="@drawable/ic_reader_next_chapter"
                app:tint="@android:color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
