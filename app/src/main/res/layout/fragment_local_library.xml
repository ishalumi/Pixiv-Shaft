<?xml version="1.0" encoding="utf-8"?>
<!--
  本地小说书库。Toolbar 抄 fragment_webview 5 件套(AppBarOverlay + popupTheme +
  navigationIcon + titleTextColor),状态栏 inset 走 BarUtils 在代码里 padding,
  不用 fitsSystemWindows(BaseActivity 开了 EdgeToEdge,会重复套 inset)。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/f5_to_deep_dark"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/six_dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow"
        app:title="@string/local_novel_entry"
        app:titleTextColor="@color/white" />

    <TextView
        android:id="@+id/breadcrumb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/f5_to_deep_dark"
        android:ellipsize="start"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:singleLine="true"
        android:textColor="@color/v3_text_2"
        android:textSize="12sp"
        tools:text="内部存储 / 小说 / 铁 / 崩铁3p" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="12dp"
            tools:listitem="@layout/cell_local_library_entry" />

        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/emptyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/local_novel_empty_no_root"
                android:textColor="@color/v3_text_2"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnPick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/local_novel_pick_folder" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
