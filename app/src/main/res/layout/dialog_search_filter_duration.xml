<?xml version="1.0" encoding="utf-8"?>
<!-- 投稿期间 picker —— relative buckets（None/Day/Week/Month/HalfYear/Year）+ 自定义起止日期。
     选 relative 清掉自定义日期，选自定义日期清掉 relative，互斥。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_v3_sheet_top"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="start|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/search_filter_v3_cancel"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/search_filter_v3_row_duration"
            android:textColor="@color/v3_text_1"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/search_filter_v3_confirm"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- relative buckets -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_v3_settings_card"
                android:clipToOutline="true"
                android:orientation="vertical">

                <include
                    android:id="@+id/row_duration_all"
                    layout="@layout/cell_search_filter_check_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_duration_day"
                    layout="@layout/cell_search_filter_check_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_duration_week"
                    layout="@layout/cell_search_filter_check_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_duration_month"
                    layout="@layout/cell_search_filter_check_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_duration_half_year"
                    layout="@layout/cell_search_filter_check_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_duration_year"
                    layout="@layout/cell_search_filter_check_row" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp" />

            <!-- 自定义起止日期 + 清除 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_v3_settings_card"
                android:clipToOutline="true"
                android:orientation="vertical">

                <include
                    android:id="@+id/row_date_start"
                    layout="@layout/cell_search_filter_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2" />

                <include
                    android:id="@+id/row_date_end"
                    layout="@layout/cell_search_filter_row" />

                <View
                    android:id="@+id/clear_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:background="@color/v3_border_2"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btn_clear_dates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:minHeight="52dp"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp"
                    android:text="@string/search_filter_v3_date_clear"
                    android:textSize="15sp"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
