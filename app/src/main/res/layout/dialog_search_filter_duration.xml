<?xml version="1.0" encoding="utf-8"?>
<!-- 投稿期间 picker —— 7 行 flat list（不限/5 个相对档/指定期间）。
     iOS pixiv 8.6.6 一致：5 个档当场算成 start_date/end_date，不发 within_last_*。
     「指定期间」打开 DateRangePickerSheet 输入自定义起止。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_v3_sheet_top"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="start|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/search_filter_v3_cancel"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/search_filter_v3_row_duration"
            android:textColor="@color/v3_text_1"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:id="@+id/picker_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_v3_settings_card"
            android:clipToOutline="true"
            android:orientation="vertical" />
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
