<?xml version="1.0" encoding="utf-8"?>
<!--
  全屏 feeds 详情页骨架（TemplateActivity 宿主，edge-to-edge）：根底色 v3_bg，
  内嵌标准 fragment_feed（id 保持 feed_root，FeedFragment 据此接管列表/刷新/空错态）。
  无 toolbar —— 承载页在 onViewCreated 里给列表补 status/nav bar inset。
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg">

    <include
        android:id="@+id/feed_root"
        layout="@layout/fragment_feed" />

</FrameLayout>
