<?xml version="1.0" encoding="utf-8"?>
<!-- 侧边栏一行（MD3 navigation drawer item）：透明底 + 按压 28dp 胶囊 ripple，图标 + 标题。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@drawable/bg_drawer_item_pill"
    android:clickable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="24dp">

    <ImageView
        android:id="@+id/drawer_row_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:importantForAccessibility="no"
        app:tint="@color/v3_text_2" />

    <TextView
        android:id="@+id/drawer_row_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/v3_text_1"
        android:textSize="15sp" />

</LinearLayout>
