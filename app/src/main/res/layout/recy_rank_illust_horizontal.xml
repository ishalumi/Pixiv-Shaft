<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <!-- V3 排行榜 hero 卡:圆角 16 CardView 裁封面 + 底部 bg_v3_card_scrim 恒暗渐变,白色标题/作者叠在
         scrim 上(替掉旧版一字一硬阴影);图未加载露出 v3_surface_2 圆角占位(日夜自适应)。同发现页 /
         V3 小说封面卡同款套路。id title/author/illust_image/user_head 保持不变(RAdapter 靠它绑定)。 -->
    <androidx.cardview.widget.CardView
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/v3_surface_2"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/illust_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/v3_surface_2"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <!-- 底部恒暗渐变蒙版:白字在任意封面上都读得清(日夜通用) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_v3_card_scrim" />

        <!-- 标题 + 作者簇,贴卡底左下 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="9dp">

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/always_white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/user_head"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/author"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#E6FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

</layout>
