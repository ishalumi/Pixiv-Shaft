<?xml version="1.0" encoding="utf-8"?>
<!-- 同义词词典管理页 —— 同义词行（缩进于目标标签下，issue #904）。v3_* 色值日夜自适配 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginTop="6dp"
    android:background="@drawable/bg_v3_surface"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/synonym_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/v3_text_1"
        android:textSize="14sp"
        tools:text="新世紀エヴァンゲリオン" />

    <!-- 备注（不参与匹配，灰色弱化显示） -->
    <TextView
        android:id="@+id/synonym_remark"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/v3_text_3"
        android:textSize="12sp"
        tools:text="新世纪福音战士" />
</LinearLayout>
