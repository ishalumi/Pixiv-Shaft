<?xml version="1.0" encoding="utf-8"?>
<!-- 引用 illust 缩略。在 illust_grid (RecyclerView) 里展示。
     - 圆角 ImageView (RoundImageView 项目里已用)
     - 右下 page_count badge,引用作品多 P 时显示
     - cell 宽度由 PlazaPostHolder 按列数动态算 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:foreground="?android:attr/selectableItemBackground">

    <net.csdn.roundview.RoundImageView
        android:id="@+id/thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="?attr/colorSurfaceContainerHighest"
        app:rRadius="10dp"
        tools:src="@mipmap/ic_launcher" />

    <!-- 缺失 meta (server 还没缓存这个 illust) 时显示 ID 占位,
         不让用户面对一片灰。点击仍可跳到详情。 -->
    <TextView
        android:id="@+id/placeholder_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="11sp"
        android:visibility="gone"
        tools:text="123456"
        tools:visibility="visible" />

</FrameLayout>
