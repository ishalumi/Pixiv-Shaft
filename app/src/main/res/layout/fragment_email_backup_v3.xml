<?xml version="1.0" encoding="utf-8"?>
<!--
  V3 账号备份 / 恢复页（承载于 TemplateActivity「邮箱备份」）。
  顶部分段切「备份 / 恢复」，下面是说明卡 + 邮箱 + 验证码 + 主操作按钮。
  所有可见态由 EmailBackupV3ViewModel.UiState 驱动，这里只是壳。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg"
    android:orientation="vertical">

    <!-- Toolbar 与设置页 (fragment_settings.xml) 同款：colorPrimary 底 + 白色居中标题 + 返回箭头。
         状态栏 inset 不用 fitsSystemWindows（BaseActivity 开了 EdgeToEdge 会双重 inset），
         改 runtime updatePadding(top=BarUtils.getStatusBarHeight())。 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/six_dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:title=" "
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow">

        <TextView
            android:id="@+id/toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/email_backup_title"
            android:textColor="@color/white"
            android:textSize="18sp" />
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="28dp">

            <!-- 已备份态：大绿勾 + 备份信息 + 解绑。已绑定时显示，替换掉下面的表单。 -->
            <LinearLayout
                android:id="@+id/bound_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/v3_glass_surface"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="32dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:contentDescription="@string/email_backup_bound_title"
                    android:src="@drawable/ic_verified_check" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/email_backup_bound_title"
                    android:textColor="@color/v3_green"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/bound_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:textColor="@color/v3_text_2"
                    android:textSize="13sp"
                    tools:text="已加密备份到 f***s@gmail.com" />

                <TextView
                    android:id="@+id/bound_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/v3_text_3"
                    android:textSize="12sp"
                    tools:text="备份时间 2026-05-23 18:41" />

                <TextView
                    android:id="@+id/btn_unbind"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_v3_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/email_backup_unbind"
                    android:textColor="@color/v3_danger"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 备份/恢复表单：未绑定（或恢复模式）时显示 -->
            <LinearLayout
                android:id="@+id/form_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- 分段控件：选中段套 bg_v3_pill_primary，由 fragment 切换 -->
            <LinearLayout
                android:id="@+id/segment_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_v3_surface"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/seg_backup"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/email_backup_seg_backup"
                    android:textColor="@color/v3_text_2"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/seg_restore"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/email_backup_seg_restore"
                    android:textColor="@color/v3_text_2"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 说明卡（玻璃面） -->
            <TextView
                android:id="@+id/description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/v3_glass_surface"
                android:lineSpacingExtra="3dp"
                android:padding="16dp"
                android:textColor="@color/v3_text_3"
                android:textSize="13sp"
                tools:text="将当前登录的 Pixiv 账号加密备份到你的邮箱……" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginStart="2dp"
                android:text="@string/email_backup_email_label"
                android:textColor="@color/v3_text_2"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/email_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_v3_surface"
                android:hint="@string/email_backup_email_hint"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:textColor="@color/v3_text_1"
                android:textColorHint="@color/v3_text_3"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btn_request_code"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_v3_button_primary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/email_backup_get_code"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/code_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_v3_surface"
                android:gravity="center"
                android:hint="@string/email_backup_code_hint"
                android:inputType="number"
                android:letterSpacing="0.25"
                android:maxLength="6"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:textColor="@color/v3_text_1"
                android:textColorHint="@color/v3_text_3"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_v3_button_primary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/email_backup_do_backup"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="@color/v3_text_3"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="验证码已发送至 you@example.com"
                tools:visibility="visible" />

            <!-- 没收到提醒：和验证码输入框一起出现（codeSent），提示去翻垃圾箱。 -->
            <TextView
                android:id="@+id/code_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="@string/email_backup_not_received"
                android:textColor="@color/v3_text_3"
                android:textSize="12sp"
                android:visibility="gone"
                tools:visibility="visible" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
