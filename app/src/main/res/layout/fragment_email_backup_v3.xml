<?xml version="1.0" encoding="utf-8"?>
<!--
  V3 账号备份 / 恢复页（承载于 TemplateActivity「邮箱备份」）。
  顶部分段切「备份 / 恢复」，下面是说明卡 + 邮箱 + 验证码 + 主操作按钮。
  所有可见态由 EmailBackupV3ViewModel.UiState 驱动，这里只是壳。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/v3_bg"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/v3_bg"
            app:contentInsetStartWithNavigation="0dp"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="@string/email_backup_title"
            app:titleTextAppearance="@style/TextAppearance.AppCompat.Title"
            app:titleTextColor="@color/v3_text_1" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="28dp">

            <!-- 分段控件：选中段套 bg_v3_pill_primary，由 fragment 切换 -->
            <LinearLayout
                android:id="@+id/segment_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_v3_surface"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/seg_backup"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/email_backup_seg_backup"
                    android:textColor="@color/v3_text_2"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/seg_restore"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/email_backup_seg_restore"
                    android:textColor="@color/v3_text_2"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 说明卡（玻璃面） -->
            <TextView
                android:id="@+id/description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/v3_glass_surface"
                android:lineSpacingExtra="3dp"
                android:padding="16dp"
                android:textColor="@color/v3_text_3"
                android:textSize="13sp"
                tools:text="将当前登录的 Pixiv 账号加密备份到你的邮箱……" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginStart="2dp"
                android:text="@string/email_backup_email_label"
                android:textColor="@color/v3_text_2"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/email_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_v3_surface"
                android:hint="@string/email_backup_email_hint"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:textColor="@color/v3_text_1"
                android:textColorHint="@color/v3_text_3"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btn_request_code"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_v3_button_primary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/email_backup_get_code"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/code_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_v3_surface"
                android:gravity="center"
                android:hint="@string/email_backup_code_hint"
                android:inputType="number"
                android:letterSpacing="0.25"
                android:maxLength="6"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:textColor="@color/v3_text_1"
                android:textColorHint="@color/v3_text_3"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_v3_button_primary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/email_backup_do_backup"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="@color/v3_text_3"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="验证码已发送至 you@example.com"
                tools:visibility="visible" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
