<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/meScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero:背景图全幅 + 底部 v3_hero_gradient fade(透明顶 → bg 底,光暗自适配,与
             fragment_history_v3 同套路)让图跟页面顺滑衔接 + avatar 行在 fade 之上,
             不踩 fade 区域,白色 pill 读得清。
             padding 必须挂在内层 LinearLayout,否则会把背景图也缩进去。
             背景图优先 profile.background_image_url(Glide + Blur,在代码里 async load),
             兜底用与侧边栏 header 同款 user_bg_main。 -->
        <FrameLayout
            android:id="@+id/heroContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="260dp">

            <ImageView
                android:id="@+id/heroBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/user_bg_main" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="72dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    app:civ_border_color="@color/always_white"
                    app:civ_border_width="2dp"
                    android:contentDescription="@null"
                    android:src="@drawable/avatar" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_me_greeting_pill"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/greetingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/subInfoText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- 亮点卡:3 列快捷入口,半压在 hero 底部(参考截图设计)。fade 区域 100dp,
             卡上拉 56dp,fade 还能露出 44dp 在卡上方,衔接平滑。
             用 androidx CardView,Material 那个会崩(见 feedback_no_materialcardview) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="-56dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/v3_menu_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@drawable/divider_vertical_1dp"
                android:dividerPadding="20dp"
                android:orientation="horizontal"
                android:showDividers="middle" />

        </androidx.cardview.widget.CardView>

        <!-- 分组网格,代码里塞 -->
        <LinearLayout
            android:id="@+id/sectionsHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="24dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
