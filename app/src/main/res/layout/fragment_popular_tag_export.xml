<?xml version="1.0" encoding="utf-8"?>
<!--
  标签热度导出 debug 页(承载于 TemplateActivity「标签热度导出」,仅 debug 侧边栏可见)。
  Toolbar 与设置页同款:colorPrimary 底 + 白色居中标题 + 返回箭头;状态栏 inset 走
  runtime updatePadding(top=BarUtils.getStatusBarHeight()),不用 fitsSystemWindows
  (BaseActivity 开了 EdgeToEdge 会双重 inset)。颜色全取 v3_*(带 values-night)白天黑夜自适配。

  结构对齐 SAF 压测页:顶部固定输入区 + 单个 weight 滚动日志区 + 底部固定主按钮。
  不嵌套同方向 NestedScrollView(内层 wrap_content 会被无界测量,滚动区为 0,fullScroll 失效)。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/six_dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:title=" "
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/tag_popular_export_entry"
            android:textColor="@color/white"
            android:textSize="18sp" />
    </androidx.appcompat.widget.Toolbar>

    <!-- 顶部固定输入区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:letterSpacing="0.02"
            android:text="@string/tag_popular_export_subtitle"
            android:textColor="@color/v3_text_3"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/v3_glass_surface"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingVertical="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tag_popular_export_tag_label"
                android:textColor="@color/v3_text_2"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/tag_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_v3_surface"
                android:hint="@string/tag_popular_export_tag_hint"
                android:inputType="text"
                android:maxLines="1"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:textColor="@color/v3_text_1"
                android:textColorHint="@color/v3_text_3"
                android:textSize="14sp"
                tools:ignore="Autofill" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/tag_popular_export_pages_label"
                android:textColor="@color/v3_text_2"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/pages_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_v3_surface"
                android:hint="@string/tag_popular_export_pages_hint"
                android:inputType="number"
                android:maxLength="2"
                android:maxLines="1"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:textColor="@color/v3_text_1"
                android:textColorHint="@color/v3_text_3"
                android:textSize="14sp"
                tools:ignore="Autofill" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.12"
            android:text="@string/tag_popular_export_log_section"
            android:textAllCaps="true"
            android:textColor="@color/v3_text_3"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 日志区:唯一滚动容器,weight 占满中间,自动滚到最新行 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/log_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/v3_glass_surface"
        android:clipToPadding="false">

        <TextView
            android:id="@+id/log_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="16dp"
            android:textColor="@color/v3_text_1"
            android:textIsSelectable="true"
            android:textSize="12sp"
            tools:text="开始:tag=「原神」,目标 10 页\n第 1 页:+30(累计 30)" />
    </androidx.core.widget.NestedScrollView>

    <!-- 底部固定主操作。bottom inset 在代码里按导航栏高度补,避免被系统栏遮住。 -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/v3_bg"
        android:elevation="@dimen/six_dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/btn_run"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_v3_button_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/tag_popular_export_run"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
