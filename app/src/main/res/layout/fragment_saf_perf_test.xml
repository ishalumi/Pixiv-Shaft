<?xml version="1.0" encoding="utf-8"?>
<!--
  SAF 写入压测页布局。结构跟 fragment_bulk_download_debug.xml 对齐
  (Toolbar + 顶部信息行 + 按钮行 + 滚动输出区),让导航/视觉一致。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/f5_to_deep_dark"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow"
        app:title="@string/saf_perf_test_entry"
        app:titleTextColor="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/saf_perf_test_tree_label"
            android:textColor="@color/v3_text_2"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/treeUriText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text="@string/saf_perf_test_tree_none"
            android:textColor="@color/v3_text_1"
            android:textIsSelectable="true"
            android:textSize="13sp"
            tools:text="content://..." />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/saf_perf_test_payload_label"
            android:textColor="@color/v3_text_2"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/payloadText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text="@string/saf_perf_test_payload_none"
            android:textColor="@color/v3_text_1"
            android:textSize="13sp"
            tools:text="loaded 1.2 MB · image/jpeg" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/v3_text_2"
            android:textSize="14sp"
            tools:text="running 1230 / 30000" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/dividerHorizontal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/btnPickTree"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/saf_perf_test_pick" />

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:text="@string/saf_perf_test_pick_image" />

        <Button
            android:id="@+id/btnDiag"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:text="@string/saf_perf_test_diag" />

        <Button
            android:id="@+id/btnPurge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/saf_perf_test_purge" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <Button
            android:id="@+id/btnRun1k"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/saf_perf_test_run_1k" />

        <Button
            android:id="@+id/btnRun5k"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:text="@string/saf_perf_test_run_5k" />

        <Button
            android:id="@+id/btnRun30k"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:text="@string/saf_perf_test_run_30k" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/saf_perf_test_cancel" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/outputScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/outputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="14dp"
            android:textColor="@color/v3_text_1"
            android:textIsSelectable="true"
            android:textSize="13sp"
            tools:text="output appears here" />
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
