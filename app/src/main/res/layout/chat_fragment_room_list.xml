<?xml version="1.0" encoding="utf-8"?>
<!-- Conversation list. Uses the shared classic-Shaft toolbar
     (chat_layout_toolbar.xml) so this surface visually matches the rest
     of the app (fragment_settings et al.). The Material3 theme overlay
     is still applied on the root because the row layout uses
     ?attr/colorOnSurface / ?attr/colorOutlineVariant. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceContainerLow"
    android:theme="@style/Theme.Material3.DayNight.NoActionBar">

    <include layout="@layout/chat_layout_toolbar" />

    <ceui.pixiv.chat.base.widget.StateLayout
        android:id="@+id/state_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_bar_layout">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

    </ceui.pixiv.chat.base.widget.StateLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
