<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="ceui.pixiv.ui.comments.CommentChildHolder" />
        <import type="ceui.pixiv.session.SessionManager" />

        <variable
            name="holder"
            type="CommentChildHolder" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="@drawable/v3_ripple_card14"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="10dp"
        android:paddingEnd="4dp"
        android:paddingBottom="10dp">

        <!-- ═══ Header: avatar · [作者] name · time ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/user_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="10dp"
                android:scaleType="centerCrop"
                app:civ_border_color="@color/v3_border_2"
                app:civ_border_width="1.5dp"
                userIcon="@{holder.comment.user}" />

            <TextView
                android:id="@+id/arthur_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/v3_author_badge_bg"
                android:includeFontPadding="false"
                android:letterSpacing="0.02"
                android:paddingStart="6dp"
                android:paddingTop="1.5dp"
                android:paddingEnd="6dp"
                android:paddingBottom="1.5dp"
                android:text="@string/string_432"
                android:textColor="@color/v3_purple"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="作者"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/user_name"
                style="@style/textMontserratSemiBold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:letterSpacing="-0.01"
                android:maxLines="1"
                android:text="@{holder.comment.user.name}"
                android:textColor="@color/v3_text_1"
                android:textSize="13.5sp"
                tools:text="回复者名字" />

            <TextView
                android:id="@+id/comment_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:letterSpacing="0.02"
                android:maxLines="1"
                android:textColor="@color/v3_text_3"
                android:textSize="10.5sp"
                tools:text="1 小时前" />
        </LinearLayout>

        <!-- ═══ Body: text or stamp ═══ -->
        <FrameLayout
            android:id="@+id/content_frame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="38dp"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/comment_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.01"
                android:lineSpacingMultiplier="1.3"
                android:textColor="@color/v3_text_2"
                android:textSize="14sp"
                tools:text="这是一条回复内容。" />

            <net.csdn.roundview.RoundImageView
                android:id="@+id/comment_stamp"
                android:layout_width="76dp"
                android:layout_height="76dp"
                app:rRadius="14dp" />
        </FrameLayout>

        <!-- ═══ Actions ═══ -->
        <LinearLayout
            android:id="@+id/action_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="38dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/reply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/v3_action_pill_bg"
                android:paddingStart="11dp"
                android:paddingTop="5dp"
                android:paddingEnd="11dp"
                android:paddingBottom="5dp"
                android:text="@string/string_176"
                android:textColor="@color/v3_text_2"
                android:textSize="11.5sp"
                android:textStyle="bold"
                visibleOrGone="@{SessionManager.INSTANCE.loggedInUid != holder.comment.user.id}" />

            <ceui.loxia.ProgressTextButton
                android:id="@+id/delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/v3_action_pill_bg"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="11dp"
                android:paddingTop="5dp"
                android:paddingEnd="11dp"
                android:paddingBottom="5dp"
                android:text="@string/string_219"
                android:textAllCaps="false"
                android:textColor="@color/v3_danger"
                android:textSize="11.5sp"
                android:textStyle="bold"
                app:ptb_progress_stroke_width="3dp"
                app:ptb_progress_width="14dp"
                visibleOrGone="@{SessionManager.INSTANCE.loggedInUid == holder.comment.user.id}" />
        </LinearLayout>
    </LinearLayout>
</layout>
