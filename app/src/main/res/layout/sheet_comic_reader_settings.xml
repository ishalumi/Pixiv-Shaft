<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/reader_settings_sheet_bg"
        android:clipToOutline="true"
        android:fillViewport="true"
        android:paddingTop="4dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="28dp">

                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center"
                    android:background="@drawable/reader_settings_handle"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="2dp"
                android:paddingTop="2dp"
                android:paddingBottom="4dp"
                android:text="@string/comic_reader_settings"
                android:textColor="@color/v3_text_1"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <!-- 阅读方式 -->
            <TextView
                style="@style/M3SetHeader"
                android:text="@string/comic_group_read"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reader_group_card"
                android:clipToOutline="true"
                android:orientation="vertical">

                <include
                    android:id="@+id/row_reading_mode"
                    layout="@layout/item_reader_setting_segmented"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_direction"
                    layout="@layout/item_reader_setting_segmented"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_fit_mode"
                    layout="@layout/item_reader_setting_segmented"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_flip_anim"
                    layout="@layout/item_reader_setting_segmented"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- 亮度 -->
            <TextView
                style="@style/M3SetHeader"
                android:text="@string/setting_group_brightness"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reader_group_card"
                android:clipToOutline="true"
                android:orientation="vertical">

                <include
                    android:id="@+id/row_sys_brightness"
                    layout="@layout/item_reader_setting_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View
                    android:id="@+id/divider_custom_brightness"
                    style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_custom_brightness"
                    layout="@layout/item_reader_setting_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_warm_filter"
                    layout="@layout/item_reader_setting_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- 屏幕 -->
            <TextView
                style="@style/M3SetHeader"
                android:text="@string/reader_section_screen"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reader_group_card"
                android:clipToOutline="true"
                android:orientation="vertical">

                <include
                    android:id="@+id/row_keep_screen_on"
                    layout="@layout/item_reader_setting_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_immersive"
                    layout="@layout/item_reader_setting_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_show_page_number"
                    layout="@layout/item_reader_setting_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_load_original"
                    layout="@layout/item_reader_setting_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_preload"
                    layout="@layout/item_reader_setting_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- 操作 -->
            <TextView
                style="@style/M3SetHeader"
                android:text="@string/setting_group_interaction"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reader_group_card"
                android:clipToOutline="true"
                android:orientation="vertical">

                <include
                    android:id="@+id/row_volume_flip"
                    layout="@layout/item_reader_setting_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <View style="@style/ReaderRowDivider"/>

                <include
                    android:id="@+id/row_tap_reversed"
                    layout="@layout/item_reader_setting_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>
