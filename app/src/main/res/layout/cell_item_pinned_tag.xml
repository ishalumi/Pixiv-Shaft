<?xml version="1.0" encoding="utf-8"?>
<!--
  「侧边栏 → 置顶标签」列表 cell。
  样式与 `cell_item_prime_tag.xml` 一致（用户需求：参考 PrimeTagItemHolder 的样式），
  数据源换成本地 search_table 解出来的 PinnedTagItemHolder。
-->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="ceui.pixiv.ui.pinned.PinnedTagItemHolder" />
        <import type="android.view.View" />

        <variable
            name="holder"
            type="PinnedTagItemHolder" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/cell_background"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/pinned_tag_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@{holder.tag.translated_name != null ? holder.tag.translated_name : holder.tag.name}"
                    android:textColor="@color/text00"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pinned_tag_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{holder.tag.name}"
                    android:textColor="@color/text20"
                    android:textSize="15sp"
                    android:visibility="@{holder.showSubtitle ? View.VISIBLE : View.GONE}" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/illusts_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="@{holder.hasPreview ? View.VISIBLE : View.GONE}">

            <net.csdn.roundview.RoundImageView
                android:id="@+id/illust_1"
                loadSquareMedia="@{holder.illust0}"
                visibleOrInvisible="@{holder.illust0 != null}"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:rRadius="2dp" />

            <net.csdn.roundview.RoundImageView
                android:id="@+id/illust_2"
                loadSquareMedia="@{holder.illust1}"
                visibleOrInvisible="@{holder.illust1 != null}"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="2dp"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toStartOf="@+id/illust_3"
                app:layout_constraintStart_toEndOf="@+id/illust_1"
                app:layout_constraintTop_toTopOf="parent"
                app:rRadius="2dp" />

            <net.csdn.roundview.RoundImageView
                android:id="@+id/illust_3"
                loadSquareMedia="@{holder.illust2}"
                visibleOrInvisible="@{holder.illust2 != null}"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/illust_2"
                app:layout_constraintTop_toTopOf="parent"
                app:rRadius="2dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>
</layout>
