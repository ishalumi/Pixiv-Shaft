<?xml version="1.0" encoding="utf-8"?>
<!--
  举报第二步：选中的类型摘要卡 + 详细描述输入 + 提交。纯 XML + MD3-E（v3_glass_surface 摘要卡 /
  bg_v3_surface 输入框 / bg_v3_button_primary 主按钮），同 fragment_email_backup_v3.xml 的表单
  视觉语言。Toolbar 走 fragment_webview 系 5 件套，状态栏 inset 用 runtime padding。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/six_dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:title=" "
        app:titleTextColor="@android:color/white">

        <TextView
            android:id="@+id/toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/white"
            android:textSize="18sp" />

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="32dp">

            <TextView
                style="@style/M3SetHeader"
                android:text="@string/violated_rule" />

            <TextView
                android:id="@+id/flag_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/v3_glass_surface"
                android:padding="16dp"
                android:textColor="@color/v3_text_1"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="过度的性描写" />

            <TextView
                style="@style/M3SetHeader"
                android:text="@string/flag_desc" />

            <EditText
                android:id="@+id/input_box"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_v3_surface"
                android:gravity="top|start"
                android:hint="@string/flag_hint"
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/v3_text_1"
                android:textColorHint="@color/v3_text_3"
                android:textSize="15sp" />

            <ceui.loxia.ProgressTextButton
                android:id="@+id/submit_flag"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_v3_button_primary"
                android:text="@string/submit_flag"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
