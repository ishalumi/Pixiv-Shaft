<?xml version="1.0" encoding="utf-8"?>
<!-- 评论输入框「表情贴图」选择面板的单格:贴纸本身是远程方图(jpg,不带透明底)。格子必须是
     圆角正方形——列宽由 GridLayoutManager(4 列)决定,固定 dp 高会被拉成矩形,故用
     ConstraintLayout + dimensionRatio=1:1 让高度恒等于列宽(同 item_illust_square 的 1:1 打法),
     圆角仍走全仓通用的 RoundImageView rRadius。 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="@drawable/v3_ripple_card14"
    android:padding="6dp">

    <net.csdn.roundview.RoundImageView
        android:id="@+id/stamp_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:rRadius="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
