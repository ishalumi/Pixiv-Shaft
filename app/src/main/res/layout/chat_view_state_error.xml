<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:theme="@style/Theme.Material3.DayNight.NoActionBar">

    <!-- Large HTTP status code, shown for HTTP errors (e.g. "404") -->
    <TextView
        android:id="@+id/tv_error_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-black"
        android:textColor="?attr/colorError"
        android:textSize="64sp"
        android:visibility="gone" />

    <!-- Fallback icon for non-HTTP errors (network, timeout, etc.) -->
    <ImageView
        android:id="@+id/iv_error_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:alpha="0.5"
        android:contentDescription="@null"
        android:src="@android:drawable/stat_notify_error" />

    <TextView
        android:id="@+id/tv_error_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="@string/chat_state_error_default"
        android:textAlignment="center"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_retry"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/chat_state_retry" />

</LinearLayout>
