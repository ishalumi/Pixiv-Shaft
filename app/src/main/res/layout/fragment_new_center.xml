<?xml version="1.0" encoding="utf-8"?>
<!-- 「发现」tab —— V3 内容货架重设计。
     旧版是「一堆跳转卡」;这版把侧边栏「发现」分组的真实内容直接铺进 tab:每个板块 = 标题 +
     「查看全部」+ 横向缩略图货架,一屏纵向滚动。全部复用现有 repo,「查看全部」跳原来的整页。
     · 顶部 header 固定不滚(抽屉 + 大标题「发现」+ 搜索图标),下方货架滚动。
     · 货架顺序:热度标签(本地策展)→ 最新 → 特辑(pixivision)→ 当前最热 → 本月收藏 → 更多分类。
     · 本月收藏 / 当前最热走自建 shaft-api-v2,Lite 渠道整段 GONE(代码里按 BuildConfig.IS_LITE)。
     · 缩略图货架卡复用排行榜 hero 卡样式(recy_rank_illust_horizontal / recy_discover_tag):
       圆角 16 + 底部 scrim + 白标题,日夜自适应。 -->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v3_bg"
        android:orientation="vertical">

        <!-- 状态栏占位:代码里按 Dev.hideMainActivityStatus 撑到 statusHeight -->
        <View
            android:id="@+id/head"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/v3_bg" />

        <!-- Header 行:抽屉入口 + 大标题「发现」+ 搜索(和「推荐」tab 一致) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/drawerButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/string_75"
                android:scaleType="centerInside"
                android:src="@drawable/ic_baseline_dns_24"
                app:tint="@color/v3_text_1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:letterSpacing="-0.02"
                android:text="@string/string_75"
                android:textColor="@color/v3_text_1"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/searchBar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/search"
                android:scaleType="centerInside"
                android:src="@drawable/ic_search_black_24dp"
                app:tint="@color/v3_text_1" />

        </LinearLayout>

        <com.scwang.smart.refresh.layout.SmartRefreshLayout
            android:id="@+id/refreshLayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- clipToPadding=false:内容滚动时贴着视口底边裁切,而不是被 24dp paddingBottom 提前
                 24dp 切一刀(那会在底部悬空一条「莫名其妙的裁切痕迹」)。padding 只用来给末尾留出滚动余量。 -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ============ 重点模块:漫画 / 小说 ============
                         这两个是独立内容大类,提到最上方做成主题色大卡,和下方「更多分类」的小 chip
                         明确分开(用户反馈:别和小入口混在一起)。卡底(seriesStripBg)/图标底(seriesIconBg)
                         在 FragmentCenter 里按主题色 tint,日夜双模;点击跳「推荐漫画」/「推荐小说」整页。 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal"
                        android:paddingStart="20dp"
                        android:paddingTop="20dp"
                        android:paddingEnd="20dp">

                        <LinearLayout
                            android:id="@+id/bigManga"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="14dp"
                            android:stateListAnimator="@animator/button_press_scale">

                            <FrameLayout
                                android:id="@+id/bigMangaIconWrap"
                                android:layout_width="42dp"
                                android:layout_height="42dp">

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:importantForAccessibility="no"
                                    android:src="@drawable/ic_baseline_palette_24"
                                    android:tint="@android:color/white" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/type_manga"
                                    android:textColor="@color/v3_text_1"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="1dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="@string/recommend_manga"
                                    android:textColor="@color/v3_text_2"
                                    android:textSize="11sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/bigNovel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="14dp"
                            android:stateListAnimator="@animator/button_press_scale">

                            <FrameLayout
                                android:id="@+id/bigNovelIconWrap"
                                android:layout_width="42dp"
                                android:layout_height="42dp">

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:importantForAccessibility="no"
                                    android:src="@drawable/ic_baseline_menu_book_24"
                                    android:tint="@android:color/white" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/type_novel"
                                    android:textColor="@color/v3_text_1"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="1dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="@string/recommend_novel"
                                    android:textColor="@color/v3_text_2"
                                    android:textSize="11sp" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- ============ 特辑(pixivision 子 fragment,置顶) ============
                         pixivision 子 fragment 自带品牌 logo + 「查看更多」头,不再另加「特辑」文字标题。
                         它的 see_more 已经跳 pixivision 列表,无需再接一个「查看全部」。logo marginTop=24 与
                         其余货架头间距一致。 -->
                    <FrameLayout
                        android:id="@+id/fragment_pivision"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- ============ 热度标签 ============ -->
                    <LinearLayout
                        android:id="@+id/tagSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingTop="24dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:letterSpacing="0.01"
                                android:text="@string/prime_tags"
                                android:textColor="@color/v3_text_1"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tagMore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:stateListAnimator="@animator/button_press_alpha"
                                android:text="@string/string_167"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="13sp"
                                app:drawableEndCompat="@drawable/ic_chevron_right_black_24dp"
                                app:drawableTint="?attr/colorPrimary" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/tagRail"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:clipToPadding="false"
                            android:overScrollMode="never"
                            android:paddingStart="20dp"
                            android:paddingEnd="8dp" />

                    </LinearLayout>

                    <!-- ============ 最新 ============ -->
                    <LinearLayout
                        android:id="@+id/latestSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingTop="24dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:letterSpacing="0.01"
                                android:text="@string/latest_work"
                                android:textColor="@color/v3_text_1"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/latestMore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:stateListAnimator="@animator/button_press_alpha"
                                android:text="@string/string_167"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="13sp"
                                app:drawableEndCompat="@drawable/ic_chevron_right_black_24dp"
                                app:drawableTint="?attr/colorPrimary" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/latestRail"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:clipToPadding="false"
                            android:overScrollMode="never"
                            android:paddingStart="20dp"
                            android:paddingEnd="8dp" />

                    </LinearLayout>

                    <!-- ============ 当前最热(shaft-api-v2,Lite GONE) ============ -->
                    <LinearLayout
                        android:id="@+id/recentSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingTop="24dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:letterSpacing="0.01"
                                android:text="@string/current_hot"
                                android:textColor="@color/v3_text_1"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/recentMore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:stateListAnimator="@animator/button_press_alpha"
                                android:text="@string/string_167"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="13sp"
                                app:drawableEndCompat="@drawable/ic_chevron_right_black_24dp"
                                app:drawableTint="?attr/colorPrimary" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recentRail"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:clipToPadding="false"
                            android:overScrollMode="never"
                            android:paddingStart="20dp"
                            android:paddingEnd="8dp" />

                    </LinearLayout>

                    <!-- ============ 本月收藏(站长推荐,shaft-api-v2,Lite GONE) ============ -->
                    <LinearLayout
                        android:id="@+id/siteSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingTop="24dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:letterSpacing="0.01"
                                android:text="@string/site_recommend"
                                android:textColor="@color/v3_text_1"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/siteMore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:stateListAnimator="@animator/button_press_alpha"
                                android:text="@string/string_167"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="13sp"
                                app:drawableEndCompat="@drawable/ic_chevron_right_black_24dp"
                                app:drawableTint="?attr/colorPrimary" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/siteRail"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:clipToPadding="false"
                            android:overScrollMode="never"
                            android:paddingStart="20dp"
                            android:paddingEnd="8dp" />

                    </LinearLayout>

                    <!-- ============ 更多分类(旧跳转卡降级成一排 chip) ============ -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="12dp"
                        android:letterSpacing="0.06"
                        android:text="@string/string_76"
                        android:textColor="@color/v3_text_2"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.flexbox.FlexboxLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        app:flexWrap="wrap">

                        <TextView
                            android:id="@+id/catWalk"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="9dp"
                            android:layout_marginBottom="9dp"
                            android:background="@drawable/bg_v3_chip"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingStart="15dp"
                            android:paddingTop="9dp"
                            android:paddingEnd="15dp"
                            android:paddingBottom="9dp"
                            android:stateListAnimator="@animator/button_press_scale"
                            android:text="@string/type_walk_through"
                            android:textColor="@color/v3_text_1"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/catFollowNovel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="9dp"
                            android:layout_marginBottom="9dp"
                            android:background="@drawable/bg_v3_chip"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingStart="15dp"
                            android:paddingTop="9dp"
                            android:paddingEnd="15dp"
                            android:paddingBottom="9dp"
                            android:stateListAnimator="@animator/button_press_scale"
                            android:text="@string/string_196"
                            android:textColor="@color/v3_text_1"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/catDiscovery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="9dp"
                            android:layout_marginBottom="9dp"
                            android:background="@drawable/bg_v3_chip"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingStart="15dp"
                            android:paddingTop="9dp"
                            android:paddingEnd="15dp"
                            android:paddingBottom="9dp"
                            android:stateListAnimator="@animator/button_press_scale"
                            android:text="@string/string_discovery"
                            android:textColor="@color/v3_text_1"
                            android:textSize="13sp" />

                        <!-- Web 首页:仅 github 渠道,Lite 里 GONE(占位功能,Coming soon) -->
                        <TextView
                            android:id="@+id/catWeb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="9dp"
                            android:layout_marginBottom="9dp"
                            android:background="@drawable/bg_v3_chip"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingStart="15dp"
                            android:paddingTop="9dp"
                            android:paddingEnd="15dp"
                            android:paddingBottom="9dp"
                            android:stateListAnimator="@animator/button_press_scale"
                            android:text="@string/street_title"
                            android:textColor="@color/v3_text_1"
                            android:textSize="13sp" />

                    </com.google.android.flexbox.FlexboxLayout>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

        </com.scwang.smart.refresh.layout.SmartRefreshLayout>

    </LinearLayout>

</layout>
