<?xml version="1.0" encoding="utf-8"?>
<!-- 画廊瀑布流封面卡:圆角 CardView 裁封面(高度由作品元数据比例决定) + 底部恒暗渐变 scrim
     + 白色标题,同排行榜 hero 卡 / V3 封面卡套路;图未加载露出 v3_surface_2 圆角占位。 -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/v3_surface_2"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/illust_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/v3_surface_2"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_v3_card_scrim"
            app:layout_constraintBottom_toBottomOf="@id/illust_image"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/illust_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingStart="10dp"
            android:paddingEnd="4dp"
            android:paddingBottom="9dp"
            android:textColor="@color/always_white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/illust_image"
            app:layout_constraintEnd_toStartOf="@id/like_button"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/like_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:padding="6dp"
            android:src="@drawable/ic_like_illust_6"
            app:layout_constraintBottom_toBottomOf="@id/illust_image"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
