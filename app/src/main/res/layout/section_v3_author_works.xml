<?xml version="1.0" encoding="utf-8"?>
<!--
  作者其他作品横向条。关键:横向 RecyclerView 全出血(match_parent、外层容器不加横向 padding)+ 自带
  12dp 内边距 + clipToPadding=true(默认)。这样卡片被裁在内容边距(12dp,与标题对齐)处,而不是被裁
  到屏幕最边(见反馈:clipToPadding=false 会让卡画进 padding 一直顶到屏幕边,正是之前的 bleed 根因)。
  首卡与标题左对齐,滚动时首/尾卡干净地切在 12dp / 屏宽-12dp 处。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/author_works_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:textColor="@color/v3_text_3"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="ARTIST'S WORKS" />

        <TextView
            android:id="@+id/author_works_see_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/see_more"
            android:textColor="@color/v3_ambient_primary"
            android:textSize="12sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/author_works_loading"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginVertical="50dp"
        android:indeterminateTint="@color/v3_text_3"
        android:visibility="gone" />

    <!-- clipToPadding 默认 true:卡片切在 12dp 内边距处(不画进 padding),不再顶到屏幕边。 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/author_works_rv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        android:overScrollMode="never"
        android:paddingHorizontal="12dp" />
</LinearLayout>
