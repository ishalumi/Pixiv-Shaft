<?xml version="1.0" encoding="utf-8"?>
<!--
  当前最热专用布局。基于 viewpager_with_tablayout.xml,额外在 toolbar 右侧加一个
  window 下拉(实时/日榜/周榜/月榜),点开 PopupMenu 切换窗口。不复用共享布局是因为
  那个被多处引用,不能为单一页面加控件。
-->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <ceui.pixiv.widgets.TopInsetLinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="?attr/colorPrimary">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/app_bar"
                android:background="?attr/colorPrimary">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:theme="@style/AppTheme.AppBarOverlay"
                    app:popupTheme="@style/AppTheme.PopupOverlay"
                    android:layout_height="?attr/actionBarSize"
                    android:elevation="@dimen/six_dp"
                    app:layout_scrollFlags="scroll|enterAlways"
                    app:navigationIcon="@drawable/ic_arrow_back_white_shadow"
                    app:title=" "
                    app:titleTextColor="@android:color/white">

                    <TextView
                        android:id="@+id/toolbar_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="@color/white"
                        android:textSize="18sp" />

                    <!-- 窗口下拉。文案/箭头由 FragmentRecentRecommend 代码设置 + PopupMenu。 -->
                    <TextView
                        android:id="@+id/window_selector"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="@dimen/eight_dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/eight_dp"
                        android:paddingTop="@dimen/four_dp"
                        android:paddingEnd="@dimen/eight_dp"
                        android:paddingBottom="@dimen/four_dp"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                </androidx.appcompat.widget.Toolbar>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_layout"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:background="?attr/colorPrimary"
                    app:tabIndicatorColor="@android:color/white"
                    app:tabIndicatorFullWidth="false"
                    app:tabMode="fixed"
                    app:tabSelectedTextColor="@android:color/white"
                    app:tabTextColor="@color/light_new_primary_color" />

            </com.google.android.material.appbar.AppBarLayout>

            <androidx.viewpager.widget.ViewPager
                android:id="@+id/view_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?android:attr/colorBackground"
                app:layout_behavior="@string/appbar_scrolling_view_behavior" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

    </ceui.pixiv.widgets.TopInsetLinearLayout>
</layout>
