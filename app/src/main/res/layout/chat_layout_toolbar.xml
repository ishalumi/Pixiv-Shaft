<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.appbar.AppBarLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/app_bar_layout"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurfaceContainerLow"
    app:liftOnScroll="false"
    app:elevation="0dp"
    android:theme="@style/Theme.Material3.DayNight.NoActionBar">

    <View
        android:id="@+id/toolbar_top_placeholder"
        android:layout_width="match_parent"
        android:background="?attr/colorSurfaceContainerLow"
        android:layout_height="0dp" />

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="?attr/colorSurfaceContainerLow">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/chat_circle_btn_bg"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:src="@drawable/baseline_arrow_back_24"
            app:tint="?attr/colorOnSurface"
            android:contentDescription="@string/chat_action_back" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_peer_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:scaleType="centerCrop"
            android:src="@drawable/chat_avatar_placeholder"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Chat.Avatar" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                android:textSize="17sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:includeFontPadding="false"
                tools:text="Gabrielle Roth" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="\@melodygardot" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/chat_circle_btn_bg"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert_black_24dp"
            app:tint="?attr/colorOnSurface"
            android:contentDescription="@string/chat_action_more"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>
</com.google.android.material.appbar.AppBarLayout>
