<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/feed_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/feed_refresh_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/feed_list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- 首屏骨架图的容器。纯表现层：只按 FeedUiState.showFullscreenLoading 显隐(见 FeedFragment.render)。
         具体画哪种骨架由 FeedFragment.onCreateSkeletonView 按布局决定(瀑布流 / 竖向小说卡)，
         在 onViewCreated 塞进来；返回 null 的页面不启用骨架(转圈圈兜底)。 -->
    <FrameLayout
        android:id="@+id/feed_skeleton"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/feed_state_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/feed_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <!-- 空态/错误态插画。运行时按状态换图(空态=empty_img 箱子 / 错误=ic_feed_error 路障锥,
             见 FeedFragment.render);两张都是灰色描边,统一用主题色派生色 SRC_IN tint(日夜双模,
             见 FeedFragment.onViewCreated)。src 只是布局预览的默认图。只在有 state 文案时显示,加载态隐藏。 -->
        <ImageView
            android:id="@+id/feed_empty_image"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="8dp"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            android:src="@mipmap/empty_img"
            android:visibility="gone" />

        <TextView
            android:id="@+id/feed_state_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
