<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <!-- 卡间距由列表的 LinearItemDecoration(12dp) 统一给,cell 本身不加 margin。 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/v3_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="1.5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- 上半:封面(左,收藏数/字数叠在封面 align bottom) + 右侧标题·收藏按钮(首行) / 系列 / 作者·日期(贴封面底部) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="90dp"
                    android:layout_height="134dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/cover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/v3_surface_2"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop" />

                    <!-- 站长推荐 score pill,叠在封面左上角。NAdapter 不 setVisibility 时 style 自带 gone。 -->
                    <TextView
                        android:id="@+id/trending_score"
                        style="@style/TrendingScorePill"
                        android:layout_gravity="top|start"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="4dp"
                        tools:text="▲ 1.2k"
                        tools:visibility="visible" />

                    <!-- AI 生成角标:novel_ai_type == 2 时显示 -->
                    <TextView
                        android:id="@+id/badge_ai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/v3_novel_ai_badge_bg"
                        android:paddingHorizontal="5dp"
                        android:paddingVertical="2dp"
                        android:text="@string/v3_detail_ai"
                        android:textColor="@android:color/white"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- 底部恒暗渐变蒙版:复用发现页图片卡同款 scrim,保证叠在封面上的白字在任意封面上都读得清(日夜通用)。 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/bg_v3_card_scrim" />

                    <!-- 封面底部信息簇:收藏数(上) + 字数(下),纵向叠放,整簇在封面内横向居中,贴封面 align bottom。 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingHorizontal="6dp"
                        android:paddingBottom="7dp">

                        <!-- 主角数据:收藏数最重(13sp bold 纯白 + 红心) -->
                        <TextView
                            android:id="@+id/bookmark_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="3dp"
                            android:gravity="center_vertical"
                            android:letterSpacing="0.01"
                            android:maxLines="1"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:drawableStartCompat="@drawable/ic_favorite_black_24dp"
                            app:drawableTint="#ff445b"
                            tools:text="8172" />

                        <!-- 次级数据:字数收一档(11sp medium 78% 白),与收藏数拉开层级 -->
                        <TextView
                            android:id="@+id/how_many_word"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.02"
                            android:maxLines="1"
                            android:textColor="#C8FFFFFF"
                            android:textSize="11sp"
                            tools:text="10842字" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 高度锁定与封面一致,靠 Space 把作者/日期簇顶到封面底部,消灭右侧空白 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="134dp"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- 首行:标题(左,占宽) + 收藏爱心(最右,与插画卡同款 ic_like_illust_6,顶对齐首行) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:letterSpacing="-0.02"
                            android:lineSpacingMultiplier="0.98"
                            android:maxLines="2"
                            android:textColor="@color/v3_text_1"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="死に戻ったら皆んな怒ってたから嘘ついた!" />

                        <ImageButton
                            android:id="@+id/like"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/string_122"
                            android:padding="@dimen/four_dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_like_illust_6"
                            app:tint="@color/not_bookmarked"
                            tools:tint="@color/has_bookmarked" />
                    </LinearLayout>

                    <!-- 系列:强调色 + medium 字重,是全卡唯一常驻的彩色文本,打破灰阶单调 -->
                    <TextView
                        android:id="@+id/series"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="2"
                        android:textColor="@color/v3_text_2"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:text="系列: しにもどり"
                        tools:visibility="visible" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <!-- 贴封面底部:作者(左) ... 日期(右),日期与作者信息同一横向水平。 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/user_head"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            app:civ_border_color="@color/v3_surface_2"
                            app:civ_border_width="1dp" />

                        <!-- 作者名:medium 字重(500)+ 次级色,比日期更有存在感又不抢标题 -->
                        <TextView
                            android:id="@+id/author"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:textColor="@color/v3_text_2"
                            android:textSize="13sp"
                            tools:text="葵由" />

                        <TextView
                            android:id="@+id/date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.02"
                            android:maxLines="1"
                            android:textColor="@color/v3_text_3"
                            android:textSize="12sp"
                            tools:text="2026-03-09" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 标签流:整卡满宽,紧凑 chip(比详情页小一号),最多 3 行,超出的标签不展示。
                 关闭「显示标签」时喂空列表折叠。 -->
            <ceui.pixiv.widgets.V3TagFlowView
                android:id="@+id/novel_tag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:flexWrap="wrap"
                app:maxLine="3" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</layout>
