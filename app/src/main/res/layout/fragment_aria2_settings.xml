<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg">

    <include
        android:id="@+id/toolbar_layout"
        layout="@layout/layout_toolbar" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <!-- 功能说明卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_v3_card"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/textMontserratBold"
                    android:text="@string/aria2_settings_title"
                    android:textColor="@color/v3_text_1"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingMultiplier="1.35"
                    android:text="@string/aria2_intro_body"
                    android:textColor="@color/v3_text_2"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- 配置卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_v3_card"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="18dp">

                <!-- 启用开关 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/aria2_enable_title"
                        android:textColor="@color/v3_text_1"
                        android:textSize="16sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/aria2_enable_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.3"
                    android:text="@string/aria2_enable_desc"
                    android:textColor="@color/v3_text_3"
                    android:textSize="12sp" />

                <!-- RPC 地址 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/aria2_rpc_url_label"
                    android:textColor="@color/v3_text_3"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/aria2_rpc_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:autofillHints=""
                    android:background="@drawable/bg_v3_chip"
                    android:fontFamily="monospace"
                    android:hint="@string/aria2_rpc_url_hint"
                    android:importantForAutofill="no"
                    android:inputType="textUri|textNoSuggestions"
                    android:maxLines="1"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/v3_text_1"
                    android:textColorHint="@color/v3_text_3"
                    android:textSize="14sp" />

                <!-- RPC 密钥 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/aria2_rpc_secret_label"
                    android:textColor="@color/v3_text_3"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/aria2_rpc_secret"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:autofillHints=""
                    android:background="@drawable/bg_v3_chip"
                    android:fontFamily="monospace"
                    android:hint="@string/aria2_rpc_secret_hint"
                    android:importantForAutofill="no"
                    android:inputType="text|textNoSuggestions"
                    android:maxLines="1"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/v3_text_1"
                    android:textColorHint="@color/v3_text_3"
                    android:textSize="14sp" />

                <!-- 远端下载目录 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/aria2_remote_dir_label"
                    android:textColor="@color/v3_text_3"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/aria2_remote_dir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:autofillHints=""
                    android:background="@drawable/bg_v3_chip"
                    android:fontFamily="monospace"
                    android:hint="@string/aria2_remote_dir_hint"
                    android:importantForAutofill="no"
                    android:inputType="textUri|textNoSuggestions"
                    android:maxLines="1"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/v3_text_1"
                    android:textColorHint="@color/v3_text_3"
                    android:textSize="14sp" />

                <!-- 操作按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/aria2_save_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_v3_pill_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="22dp"
                        android:paddingVertical="11dp"
                        android:text="@string/aria2_btn_save"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/aria2_test_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_v3_pill_secondary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="11dp"
                        android:text="@string/aria2_btn_test"
                        android:textColor="#6C5CE7"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
