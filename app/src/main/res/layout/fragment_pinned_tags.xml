<?xml version="1.0" encoding="utf-8"?>
<!--
  「侧边栏 → 置顶标签」页布局（feeds 框架版）。
  Toolbar 用 fragment_settings / fragment_webview 同款 5 件套（colorPrimary 底 + 白标题 +
  返回箭头 + AppBarOverlay / PopupOverlay + title=" " 占位）+ 额外「清空」按钮；BaseActivity
  开了 EdgeToEdge，状态栏 inset 走 runtime `updatePadding(top=BarUtils.getStatusBarHeight())`，
  不用 fitsSystemWindows（双重 inset 会让顶部多空一截）。
  列表区改用 feeds 框架标准 fragment_feed include（id 保持 feed_root）：下拉刷新 / 空态 /
  加载态统一交给框架管理，不再自己叠 empty_layout。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/f5_to_deep_dark"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/six_dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:title=" "
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow">

        <TextView
            android:id="@+id/toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/pinned_tags"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/clear_all"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:paddingHorizontal="@dimen/sixteen_dp"
            android:text="@string/clear"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:visibility="gone" />

    </androidx.appcompat.widget.Toolbar>

    <include
        android:id="@+id/feed_root"
        layout="@layout/fragment_feed"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
