<?xml version="1.0" encoding="utf-8"?>
<!-- 同义词词典管理页 —— 目标标签行（issue #904）。v3_* 色值日夜自适配 -->
<!-- 垂直 padding 放在子 View 上（而不是父容器）：让右侧展开/收起计数区域（issue #905）
     的点击热区覆盖整行高度，视觉效果与父容器统一 padding 完全一致 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:background="@drawable/v3_glass_surface"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="0dp">

    <TextView
        android:id="@+id/target_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingVertical="12dp"
        android:textColor="@color/v3_text_1"
        android:textSize="15sp"
        android:textStyle="bold"
        tools:text="EVA" />

    <TextView
        android:id="@+id/synonym_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingVertical="12dp"
        android:textColor="@color/v3_text_3"
        android:textSize="12sp"
        tools:text="▸ 5 个同义词" />
</LinearLayout>
