<?xml version="1.0" encoding="utf-8"?>
<!--
  「按标签筛选」(收藏标签浏览) 页布局 (feeds 框架版,替代 legacy fragment_booked_tag)。
  Toolbar 抄 fragment_toolbar_feed / fragment_pinned_tags 5 件套 (colorPrimary 底 + 白标题 +
  返回箭头 + AppBarOverlay/PopupOverlay + title=" " 占位居中 TextView);状态栏 inset 走 runtime
  updatePadding(top=BarUtils.getStatusBarHeight()),不用 fitsSystemWindows(BaseActivity 开了
  EdgeToEdge,会把 status+nav 两个 inset 都当 padding 套上)。
  Toolbar 下是客户端搜索栏,searchInput / searchClear / searchPreloadProgress 沿用 legacy
  fragment_booked_tag 的 id 与子视图结构;列表区用 feeds 标准 fragment_feed include (id feed_root)。
  searchPreloadProgress 保留占位:预加载已挪到首屏 load() 一次性拉全,由框架 loading 圈反馈,
  搜索时全量已在内存,此进度条常隐藏(见 BookedTagFeedFragment 注释)。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/six_dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:title=" "
        app:titleTextColor="@android:color/white">

        <TextView
            android:id="@+id/toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="18sp" />

    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/v3_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/edittext_round_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_gray_search" />

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/booked_tag_search_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingHorizontal="8dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/about_user_left"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/searchClear"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_clear_search"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/searchPreloadProgress"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <include
        android:id="@+id/feed_root"
        layout="@layout/fragment_feed"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
