<?xml version="1.0" encoding="utf-8"?>
<!--
  网络测试页（承载于 TemplateActivity「网络测试」）。
  Toolbar 与设置页同款：colorPrimary 底 + 白色居中标题 + 返回箭头；状态栏 inset 走
  runtime updatePadding(top=BarUtils.getStatusBarHeight())，不用 fitsSystemWindows
  (BaseActivity 开了 EdgeToEdge 会双重 inset)。

  结构：顶部环境 chip（DoH / 直连）→ 总览卡（跑完显示）→ 每个目标一张玻璃卡
  (代码里动态填 item_network_test_target / _step) → 作品 API 探测卡 → 原始日志卡。
  底部固定主操作按钮。所有可见态由 NetworkTestViewModel 驱动。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v3_bg"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/six_dp"
        app:navigationIcon="@drawable/baseline_arrow_back_24">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/nav_network_test_entry"
            android:textColor="@color/white"
            android:textSize="18sp" />
    </androidx.appcompat.widget.Toolbar>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- 顶部一行：副标题 + 环境 chip。chip 背景在代码里按开关状态染色。 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.02"
                android:text="@string/network_test_subtitle"
                android:textColor="@color/v3_text_3"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chip_doh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="安全 DNS 开" />

                <TextView
                    android:id="@+id/chip_direct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="直连关" />
            </LinearLayout>

            <!-- 总览卡：跑完才显示。大状态行 + 副说明。 -->
            <LinearLayout
                android:id="@+id/summary_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/v3_glass_surface_xl"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="18dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/summary_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="7dp"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="● 网络通畅" />

                <TextView
                    android:id="@+id/summary_sub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/v3_text_2"
                    android:textSize="13sp"
                    tools:text="未检测到 DNS 污染，握手正常" />
            </LinearLayout>

            <!-- 空态：首次进入时的提示，跑测后隐藏。 -->
            <LinearLayout
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/v3_glass_surface"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛰"
                    android:textSize="40sp"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="@string/network_test_empty_hint"
                    android:textColor="@color/v3_text_3"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- 连通性诊断结果区：跑测后显示。 -->
            <LinearLayout
                android:id="@+id/results_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:letterSpacing="0.12"
                    android:text="@string/network_test_section_targets"
                    android:textAllCaps="true"
                    android:textColor="@color/v3_text_3"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/results_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- 作品 API 探测卡：独立功能，始终可见。 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:letterSpacing="0.12"
                android:text="@string/network_test_section_illust"
                android:textAllCaps="true"
                android:textColor="@color/v3_text_3"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/v3_glass_surface"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingVertical="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/illust_id_input"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_v3_surface"
                        android:hint="@string/network_test_illust_hint"
                        android:inputType="number"
                        android:maxLength="12"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/v3_text_1"
                        android:textColorHint="@color/v3_text_3"
                        android:textSize="14sp"
                        tools:ignore="Autofill" />

                    <TextView
                        android:id="@+id/btn_illust_test"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_v3_button_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="96dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="13dp"
                        android:text="@string/network_test_illust_run"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/illust_result_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- 原始日志卡：头部可展开/收起；内部等宽日志可选中复制。 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.12"
                    android:text="@string/network_test_section_rawlog"
                    android:textAllCaps="true"
                    android:textColor="@color/v3_text_3"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_rawlog_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="@string/network_test_rawlog_show"
                    android:textColor="@color/v3_blue"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/raw_log_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/v3_glass_surface"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:padding="16dp"
                android:textColor="@color/v3_text_1"
                android:textIsSelectable="true"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="========== www.pixiv.net =========="
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 底部固定主操作。bottom inset 在代码里按导航栏高度补，避免被系统栏遮住。 -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/v3_bg"
        android:elevation="@dimen/six_dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/btn_run"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_v3_button_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/network_test_run"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_copy"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_v3_button_outline"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingHorizontal="18dp"
            android:text="@string/network_test_copy_log"
            android:textColor="@color/v3_text_2"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
