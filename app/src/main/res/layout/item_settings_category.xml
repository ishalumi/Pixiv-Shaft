<?xml version="1.0" encoding="utf-8"?>
<!-- 设置主页的一个分类行：tonal 圆底图标 + 标题 + 子项预览 + 箭头。背景按位置在代码里设。 -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:background="@drawable/bg_m3_row_mid"
    android:clickable="true"
    android:minHeight="72dp"
    android:paddingStart="14dp"
    android:paddingTop="13dp"
    android:paddingEnd="18dp"
    android:paddingBottom="13dp">

    <FrameLayout
        android:id="@+id/category_icon_wrap"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_m3_icon_circle">

        <ImageView
            android:id="@+id/category_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:importantForAccessibility="no"
            app:tint="?attr/colorPrimary" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="28dp"
        android:layout_toEndOf="@id/category_icon_wrap"
        android:orientation="vertical">

        <TextView
            android:id="@+id/category_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/v3_text_1"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/category_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/v3_text_2"
            android:textSize="13sp" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:drawableEnd="@drawable/ic_arrow_right"
        android:importantForAccessibility="no" />

</RelativeLayout>
