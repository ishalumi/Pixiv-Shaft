<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end|top"
    android:paddingHorizontal="12dp"
    android:paddingVertical="6dp"
    android:theme="@style/Theme.Material3.DayNight.NoActionBar">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="4dp"
        app:cardBackgroundColor="?attr/colorPrimary"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:shapeAppearance="@style/ShapeAppearance.Chat.Bubble.Sent">

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="240dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp"
            tools:text="I need to find a 2BR apartment in SF Mission district. Budget around $2,800/mo, pet-friendly." />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:src="@drawable/chat_avatar_placeholder"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Chat.Avatar" />
</LinearLayout>
