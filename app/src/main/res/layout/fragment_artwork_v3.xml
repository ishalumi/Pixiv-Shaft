<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v3_bg">

        <!-- 手动下拉刷新:只重新拉取 illust 详情本身,懒加载区块(评论/作者其他作品/相关作品)不动。
             加载更多由 RecyclerView 的滚动监听负责,这里关掉 SmartRefreshLayout 自带的 footer 手势。 -->
        <com.scwang.smart.refresh.layout.SmartRefreshLayout
            android:id="@+id/refresh_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:srlEnableLoadMore="false">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never" />
        </com.scwang.smart.refresh.layout.SmartRefreshLayout>

        <LinearLayout
            android:id="@+id/top_overlay_column"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back_white_shadow">

                <TextView
                    android:id="@+id/toolbar_title"
                    style="@style/textMontserratBold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:alpha="0.0"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/v3_text_1"
                    android:textSize="18sp" />

                <ImageView
                    android:id="@+id/nav_more"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@null"
                    android:padding="10dp"
                    android:src="@drawable/ic_more_vert_black_24dp"
                    app:tint="@color/v3_text_1" />
            </androidx.appcompat.widget.Toolbar>

            <LinearLayout
                android:id="@+id/page_status_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#CCFF6B6B"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/page_status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/page_status_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="@string/image_load_status_retry_all"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Floating "收起" pill: anchored top-end, visible only while the
             multi-page illust is expanded. topMargin is driven at runtime
             from top_overlay_column.bottom so the pill stays clear of the
             retry banner (see issue #881). -->
        <LinearLayout
            android:id="@+id/collapse_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_v3_expand_pill"
            android:clickable="true"
            android:elevation="8dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="14dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_keyboard_arrow_up_black_24dp"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.02"
                android:text="@string/v3_collapse_pages_title"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Floating action bar (download + bookmark + private bookmark) -->
        <LinearLayout
            android:id="@+id/fab_bar"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_v3_fab_bar"
            android:elevation="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp">

            <FrameLayout
                android:id="@+id/fab_download_container"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/fab_download"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="false"
                    android:contentDescription="@null"
                    android:focusable="false"
                    android:padding="8dp"
                    android:src="@drawable/ic_file_download_black_24dp"
                    app:tint="@color/white" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/fab_download_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminate="false"
                    android:visibility="gone"
                    app:indicatorColor="@color/white"
                    app:indicatorSize="24dp"
                    app:trackColor="@color/voice_record_track_color"
                    app:trackCornerRadius="4dp"
                    app:trackThickness="3dp" />
            </FrameLayout>

            <!-- 颜色只是深色模式默认值,浅色模式下由 ArtworkV3Fragment 按 palette.floatingPillContent 重刷 -->
            <View
                android:id="@+id/fab_divider"
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="2dp"
                android:background="#33FFFFFF" />

            <ImageView
                android:id="@+id/fab_bookmark"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:padding="8dp"
                android:src="@drawable/ic_favorite_black_24dp"
                app:tint="@color/white" />

        </LinearLayout>

        <!-- issue #569: 详情数据不完整(网页精简来源)时回 API 拉完整版,期间居中转圈圈 -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/loading_full_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorSize="44dp"
            app:trackThickness="4dp" />

        <!-- 评论输入浮层:平时不常驻(整条透明、输入栏 GONE),点评论区「留下你的评论吧」入口才浮出
             (见 ArtworkV3Fragment.showComposer)。整条 LinearLayout 就是 BottomPanelCoordinator 的
             panelRoot——gravity=bottom + wrap_content:coordinator 给它加底 padding 顶键盘/面板时,顶排
             的输入栏会被抬到键盘/面板之上,底部 padding(透明)落在键盘背后。跟评论详情页复用同一套
             attachBottomPanel + 表情/贴图面板,只是这里只发顶层评论(回复走完整评论列表页)。 -->
        <LinearLayout
            android:id="@+id/composer_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical">

            <!-- 输入栏:平时 GONE,点入口才 VISIBLE。底色不透明,盖住浮层下方的详情内容。 -->
            <LinearLayout
                android:id="@+id/comment_input_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/v3_bg"
                android:elevation="12dp"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageButton
                    android:id="@+id/emoji_toggle"
                    android:layout_width="40dp"
                    android:layout_height="44dp"
                    android:layout_gravity="bottom"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/comment_emoji_picker"
                    android:padding="9dp"
                    android:src="@drawable/chat_ic_emoji"
                    app:tint="@color/v3_text_3" />

                <EditText
                    android:id="@+id/comment_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@android:color/transparent"
                    android:hint="@string/string_49"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="4"
                    android:minHeight="46dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="11dp"
                    android:textColor="@color/v3_text_1"
                    android:textColorHint="@color/v3_text_3"
                    android:textSize="15sp" />

                <ceui.loxia.ProgressImageButton
                    android:id="@+id/send_button"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="bottom"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/plaza_send"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/chat_ic_send"
                    app:tint="@color/always_white" />
            </LinearLayout>

            <!-- 「绘文字」/「表情贴图」双 tab 面板,跟系统键盘互斥 + 等高切换(交给
                 BottomPanelCoordinator)。XML 高度只是首帧占位,展示前按实测键盘高度覆盖。 -->
            <LinearLayout
                android:id="@+id/emoji_panel_container"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="@color/v3_surface_2"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/tab_kaomoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="@string/comment_emoji_tab_kaomoji"
                        android:textColor="@color/v3_text_1"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tab_stamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:text="@string/comment_emoji_tab_stamp"
                        android:textColor="@color/v3_text_2"
                        android:textSize="13sp" />
                </LinearLayout>

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/emoji_pager"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

    </FrameLayout>

</layout>
