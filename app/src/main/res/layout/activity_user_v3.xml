<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data />

    <!-- 手动下拉刷新:只重新拉取用户详情 API 本身。
         CoordinatorLayout 套下拉刷新需配合 AppBar offset 监听
         (只在完全展开时 enable),见 UserActivityV3.setupRefresh()。 -->
    <com.scwang.smart.refresh.layout.SmartRefreshLayout
        android:id="@+id/refresh_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:srlEnableLoadMore="false">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/v3_bg">

            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/app_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:theme="@style/AppTheme.AppBarOverlay"
                app:elevation="0dp">

                <com.google.android.material.appbar.CollapsingToolbarLayout
                    android:id="@+id/toolbar_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:contentScrim="@color/v3_bg"
                    app:layout_scrollFlags="scroll|exitUntilCollapsed"
                    app:statusBarScrim="@android:color/transparent"
                    app:titleEnabled="false">

                    <!-- 身份区:banner 矮条 + 头像下凸 + 名字 + 内联统计,一起随 CTL collapse。
                         clipChildren=false 让头像能下凸画到 banner 之外。 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical">

                        <!-- Banner 矮条 190dp,头像/关注按钮压在其下沿 -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="190dp"
                            android:clipChildren="false">

                            <View
                                android:id="@+id/banner_placeholder"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_v3_banner_placeholder" />

                            <ImageView
                                android:id="@+id/banner_image"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:visibility="gone" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="120dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_v3_banner_gradient" />

                            <!-- Avatar (premium ring) 左下,下凸 42dp 压 banner 下沿 -->
                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:layout_marginStart="20dp"
                                android:layout_marginBottom="-42dp">

                                <View
                                    android:id="@+id/premium_ring"
                                    android:layout_width="94dp"
                                    android:layout_height="94dp"
                                    android:layout_gravity="center"
                                    android:background="@drawable/bg_v3_avatar_ring_premium"
                                    android:visibility="gone" />

                                <de.hdodenhof.circleimageview.CircleImageView
                                    android:id="@+id/user_avatar"
                                    android:layout_width="88dp"
                                    android:layout_height="88dp"
                                    android:layout_gravity="center"
                                    android:scaleType="centerCrop"
                                    app:civ_border_color="?attr/colorPrimary"
                                    app:civ_border_width="1.5dp" />

                                <FrameLayout
                                    android:id="@+id/premium_badge"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="bottom|end"
                                    android:background="@drawable/bg_v3_premium_badge"
                                    android:visibility="gone">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:text="★"
                                        android:textColor="#1A1A2E"
                                        android:textSize="12sp" />
                                </FrameLayout>
                            </FrameLayout>

                            <!-- 私信 + 关注 右下,底边下沉到与头像同一基线(跟 avatar 一样下凸 42dp) -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|end"
                                android:layout_marginEnd="20dp"
                                android:layout_marginBottom="-42dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/msg_btn"
                                    android:layout_width="42dp"
                                    android:layout_height="42dp"
                                    android:layout_marginEnd="8dp"
                                    android:background="@drawable/bg_v3_msg_btn"
                                    android:padding="10dp"
                                    android:src="@drawable/ic_baseline_mail_outline_24"
                                    android:visibility="gone"
                                    app:tint="@color/v3_text_2" />

                                <FrameLayout
                                    android:id="@+id/follow_layout"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content">

                                    <ceui.loxia.ProgressTextButton
                                        android:id="@+id/follow"
                                        android:layout_width="wrap_content"
                                        android:layout_height="42dp"
                                        android:background="@drawable/bg_v3_pill_primary"
                                        android:gravity="center"
                                        android:paddingHorizontal="30dp"
                                        android:text="@string/follow"
                                        android:textColor="@color/v3_text_1"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:visibility="gone"
                                        app:ptb_progress_stroke_width="3dp"
                                        app:ptb_progress_width="14dp" />

                                    <ceui.loxia.ProgressTextButton
                                        android:id="@+id/unfollow"
                                        android:layout_width="wrap_content"
                                        android:layout_height="42dp"
                                        android:background="@drawable/bg_v3_pill_secondary"
                                        android:gravity="center"
                                        android:paddingHorizontal="30dp"
                                        android:text="@string/unfollow"
                                        android:textColor="#E6C4B5FD"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:visibility="gone"
                                        app:ptb_progress_stroke_width="3dp"
                                        app:ptb_progress_width="14dp" />
                                </FrameLayout>
                            </LinearLayout>
                        </FrameLayout>

                        <!-- Profile 文本区:banner 之下,顶部留白避让下凸的头像 -->
                        <LinearLayout
                            android:id="@+id/profile_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="20dp"
                            android:paddingTop="52dp"
                            android:paddingEnd="20dp"
                            android:paddingBottom="18dp">

                            <!-- Name + Official badge -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/user_name"
                                    style="@style/textMontserratSemiBold"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:maxWidth="280dp"
                                    android:textColor="@color/v3_text_1"
                                    android:textSize="25sp"
                                    android:textStyle="bold"
                                    tools:text="ひとはﾁｬﾝ" />

                                <TextView
                                    android:id="@+id/badge_official"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/bg_v3_badge_official"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:text="@string/v3_official"
                                    android:textAllCaps="true"
                                    android:textColor="#FFFFFFFF"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:visibility="gone" />
                            </LinearLayout>

                            <!-- Handle -->
                            <TextView
                                android:id="@+id/user_handle"
                                style="@style/textMontserratMedium"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:textColor="@color/v3_text_3"
                                android:textSize="13sp"
                                tools:text="@hitohachan" />

                            <!-- Web-only badges row (互相关注 / 好P友) -->
                            <LinearLayout
                                android:id="@+id/badges_row"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal"
                                android:visibility="gone">

                                <TextView
                                    android:id="@+id/badge_follows_you"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="4dp"
                                    android:text="@string/v3_follows_you"
                                    android:textColor="@color/v3_text_2"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/badge_mypixiv"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="4dp"
                                    android:text="@string/v3_mypixiv_badge"
                                    android:textColor="@color/v3_text_2"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:visibility="gone" />
                            </LinearLayout>

                            <!-- 内联统计条:关注 · 好P友 · 收藏,每段可点。
                                 数字(18sp Montserrat)和标签(12sp CJK)字体盒高度差异大,
                                 center_vertical 会让基线错位看起来没对齐,必须走基线对齐:
                                 容器靠 baselineAlignedChildIndex 把数字的基线暴露出去。 -->
                            <LinearLayout
                                android:id="@+id/stats_strip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:id="@+id/stat_following"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:baselineAlignedChildIndex="0"
                                    android:orientation="horizontal"
                                    android:paddingVertical="2dp">

                                    <TextView
                                        android:id="@+id/stat_following_num"
                                        style="@style/textMontserratBold"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/v3_stat_following_num"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        tools:text="111" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="5dp"
                                        android:text="@string/v3_label_following"
                                        android:textColor="@color/v3_text_3"
                                        android:textSize="12sp" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginHorizontal="12dp"
                                    android:alpha="0.5"
                                    android:text="·"
                                    android:textColor="@color/v3_text_3"
                                    android:textSize="16sp" />

                                <LinearLayout
                                    android:id="@+id/stat_mypixiv"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:baselineAlignedChildIndex="0"
                                    android:orientation="horizontal"
                                    android:paddingVertical="2dp">

                                    <TextView
                                        android:id="@+id/stat_mypixiv_num"
                                        style="@style/textMontserratBold"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/v3_stat_mypixiv_num"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        tools:text="0" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="5dp"
                                        android:text="@string/v3_label_mypixiv"
                                        android:textColor="@color/v3_text_3"
                                        android:textSize="12sp" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/stat_bookmark_sep"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginHorizontal="12dp"
                                    android:alpha="0.5"
                                    android:text="·"
                                    android:textColor="@color/v3_text_3"
                                    android:textSize="16sp"
                                    android:visibility="gone" />

                                <LinearLayout
                                    android:id="@+id/stat_bookmark"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:baselineAlignedChildIndex="0"
                                    android:orientation="horizontal"
                                    android:paddingVertical="2dp"
                                    android:visibility="gone">

                                    <TextView
                                        android:id="@+id/stat_bookmark_num"
                                        style="@style/textMontserratBold"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/v3_text_1"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        tools:text="147" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="5dp"
                                        android:text="@string/v3_label_bookmarks"
                                        android:textColor="@color/v3_text_3"
                                        android:textSize="12sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Toolbar 仍挂 CTL 里(collapseMode=pin),但 CTL flags=scroll,会跟 CTL 一起滚出 -->
                    <androidx.appcompat.widget.Toolbar
                        android:id="@+id/toolbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_collapseMode="pin"
                        app:navigationIcon="@drawable/ic_arrow_back_white_shadow">

                        <TextView
                            android:id="@+id/toolbar_title"
                            style="@style/textMontserratBold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:alpha="0.0"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:textColor="@color/v3_text_1"
                            android:textSize="18sp" />

                        <ImageView
                            android:id="@+id/more_action"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_gravity="end"
                            android:padding="10dp"
                            android:src="@drawable/ic_more_vert_black_24dp"
                            android:visibility="gone"
                            app:tint="@color/v3_text_1" />
                    </androidx.appcompat.widget.Toolbar>

                    <!-- Loading indicator -->
                    <ProgressBar
                        android:id="@+id/progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/v3_text_1"
                        android:visibility="invisible" />

                </com.google.android.material.appbar.CollapsingToolbarLayout>

                <!-- Pinned tab strip between header & paged content -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/v3_bg"
                    app:tabGravity="fill"
                    app:tabIndicatorColor="@color/v3_text_1"
                    app:tabIndicatorFullWidth="false"
                    app:tabMode="fixed"
                    app:tabSelectedTextColor="@color/v3_text_1"
                    app:tabTextColor="@color/v3_text_3" />

                <!-- 标签筛选条已迁入插画 Tab 页面内部(fragment_user_v3_illust_tab.xml)——
                     放这里(pinned 区)会导致左右切 tab 时列表滑走了它还钉着不动。 -->

            </com.google.android.material.appbar.AppBarLayout>

            <!-- Paged content: 插画 / 漫画 / 小说 / 收藏 / 资料 -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/view_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/v3_bg"
                app:layout_behavior="@string/appbar_scrolling_view_behavior" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

    </com.scwang.smart.refresh.layout.SmartRefreshLayout>
</layout>
