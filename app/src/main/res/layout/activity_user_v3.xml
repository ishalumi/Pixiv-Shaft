<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data />

    <!-- 手动下拉刷新:只重新拉取用户详情 API 本身。
         CoordinatorLayout 套下拉刷新需配合 AppBar offset 监听
         (只在完全展开时 enable),见 UserActivityV3.setupRefresh()。 -->
    <com.scwang.smart.refresh.layout.SmartRefreshLayout
        android:id="@+id/refresh_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:srlEnableLoadMore="false">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v3_bg">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:theme="@style/AppTheme.AppBarOverlay"
            app:elevation="0dp">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/toolbar_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:contentScrim="@color/v3_bg"
                app:layout_scrollFlags="scroll|exitUntilCollapsed"
                app:statusBarScrim="@android:color/transparent"
                app:titleEnabled="false">

                <!-- 整个 TabLayout 之上的内容都放进 CTL,一起 collapse;banner 维持 300dp。 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Banner 段: 图片固定 300dp,profile_header 覆盖在底部 -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="300dp">

                        <View
                            android:id="@+id/banner_placeholder"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_v3_banner_placeholder" />

                        <ImageView
                            android:id="@+id/banner_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="160dp"
                            android:layout_gravity="bottom"
                            android:background="@drawable/bg_v3_banner_gradient" />

                        <!-- Profile header (avatar 半压 banner 下沿) -->
                        <LinearLayout
                            android:id="@+id/profile_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:orientation="vertical"
                            android:paddingHorizontal="20dp"
                            android:paddingBottom="16dp">

                            <!-- Avatar row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="bottom"
                                android:orientation="horizontal">

                                <!-- Avatar with premium ring -->
                                <FrameLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content">

                                    <View
                                        android:id="@+id/premium_ring"
                                        android:layout_width="94dp"
                                        android:layout_height="94dp"
                                        android:background="@drawable/bg_v3_avatar_ring_premium"
                                        android:visibility="gone" />

                                    <de.hdodenhof.circleimageview.CircleImageView
                                        android:id="@+id/user_avatar"
                                        android:layout_width="88dp"
                                        android:layout_height="88dp"
                                        android:layout_gravity="center"
                                        android:scaleType="centerCrop"
                                        app:civ_border_color="@color/v3_bg"
                                        app:civ_border_width="3dp" />

                                    <FrameLayout
                                        android:id="@+id/premium_badge"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_gravity="bottom|end"
                                        android:background="@drawable/bg_v3_premium_badge"
                                        android:visibility="gone">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center"
                                            android:text="★"
                                            android:textColor="#1A1A2E"
                                            android:textSize="12sp" />
                                    </FrameLayout>
                                </FrameLayout>

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:layout_weight="1" />

                                <!-- Actions: message + follow -->
                                <ImageView
                                    android:id="@+id/msg_btn"
                                    android:layout_width="42dp"
                                    android:layout_height="42dp"
                                    android:layout_marginEnd="8dp"
                                    android:layout_marginBottom="8dp"
                                    android:background="@drawable/bg_v3_msg_btn"
                                    android:padding="10dp"
                                    android:src="@drawable/ic_baseline_mail_outline_24"
                                    android:visibility="gone"
                                    app:tint="@color/v3_text_2" />

                                <FrameLayout
                                    android:id="@+id/follow_layout"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp">

                                    <ceui.loxia.ProgressTextButton
                                        android:id="@+id/follow"
                                        android:layout_width="wrap_content"
                                        android:layout_height="42dp"
                                        android:background="@drawable/bg_v3_pill_primary"
                                        android:gravity="center"
                                        android:paddingHorizontal="28dp"
                                        android:text="@string/follow"
                                        android:textColor="@color/v3_text_1"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:visibility="gone"
                                        app:ptb_progress_stroke_width="3dp"
                                        app:ptb_progress_width="14dp" />

                                    <ceui.loxia.ProgressTextButton
                                        android:id="@+id/unfollow"
                                        android:layout_width="wrap_content"
                                        android:layout_height="42dp"
                                        android:background="@drawable/bg_v3_pill_secondary"
                                        android:gravity="center"
                                        android:paddingHorizontal="28dp"
                                        android:text="@string/unfollow"
                                        android:textColor="#E6C4B5FD"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:visibility="gone"
                                        app:ptb_progress_stroke_width="3dp"
                                        app:ptb_progress_width="14dp" />
                                </FrameLayout>
                            </LinearLayout>

                            <!-- Name + Official badge -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/user_name"
                                    style="@style/textMontserratSemiBold"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/v3_text_1"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    tools:text="ひとはﾁｬﾝ" />

                                <TextView
                                    android:id="@+id/badge_official"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/bg_v3_badge_official"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:text="@string/v3_official"
                                    android:textAllCaps="true"
                                    android:textColor="#FFFFFFFF"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:visibility="gone" />
                            </LinearLayout>

                            <!-- Handle + ID -->
                            <TextView
                                android:id="@+id/user_handle"
                                style="@style/textMontserratMedium"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/v3_text_3"
                                android:textSize="13sp"
                                tools:text="@hitohachan · ID: 62059105" />

                            <!-- Web-only badges row -->
                            <LinearLayout
                                android:id="@+id/badges_row"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal"
                                android:visibility="gone">

                                <TextView
                                    android:id="@+id/badge_follows_you"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="4dp"
                                    android:text="@string/v3_follows_you"
                                    android:textColor="@color/v3_text_2"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/badge_mypixiv"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="4dp"
                                    android:text="@string/v3_mypixiv_badge"
                                    android:textColor="@color/v3_text_2"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:visibility="gone" />
                            </LinearLayout>
                        </LinearLayout>

                    </FrameLayout>

                    <!-- Stats + Quick Nav (banner 之下,仍在 CTL 内,跟 banner 一起滚) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <!-- Stats Row (following + mypixiv only) -->
                        <LinearLayout
                            android:id="@+id/stats_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_v3_surface"
                            android:orientation="horizontal"
                            android:paddingVertical="16dp">

                            <LinearLayout
                                android:id="@+id/stat_following"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/stat_following_num"
                                    style="@style/textMontserratBold"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/v3_stat_following_num"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="16" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:letterSpacing="0.1"
                                    android:text="@string/v3_label_following"
                                    android:textAllCaps="true"
                                    android:textColor="@color/v3_text_3"
                                    android:textSize="9sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/stat_mypixiv"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/stat_mypixiv_num"
                                    style="@style/textMontserratBold"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/v3_stat_mypixiv_num"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="3" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:letterSpacing="0.1"
                                    android:text="@string/v3_label_mypixiv"
                                    android:textAllCaps="true"
                                    android:textColor="@color/v3_text_3"
                                    android:textSize="9sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Quick Navigation Tags -->
                        <TextView
                            android:id="@+id/nav_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.12"
                            android:text="@string/v3_label_navigate"
                            android:textAllCaps="true"
                            android:textColor="@color/v3_text_3"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <com.zhy.view.flowlayout.TagFlowLayout
                            android:id="@+id/nav_tags"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:visibility="gone" />

                        <!-- issue #569: 按 Tag 筛选该画师插画作品 -->
                        <TextView
                            android:id="@+id/illust_tag_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:letterSpacing="0.12"
                            android:text="@string/v3_label_illust_tags"
                            android:textAllCaps="true"
                            android:textColor="@color/v3_text_3"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <com.zhy.view.flowlayout.TagFlowLayout
                            android:id="@+id/illust_tag_flow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Toolbar 仍挂在 CTL 里(collapseMode=pin),但 CTL flags=scroll,所以会跟 CTL 一起滚出去 -->
                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="pin"
                    app:navigationIcon="@drawable/ic_arrow_back_white_shadow">

                    <TextView
                        android:id="@+id/toolbar_title"
                        style="@style/textMontserratBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:alpha="0.0"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:textColor="@color/v3_text_1"
                        android:textSize="18sp" />

                    <ImageView
                        android:id="@+id/more_action"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="end"
                        android:padding="10dp"
                        android:src="@drawable/ic_more_vert_black_24dp"
                        android:visibility="gone"
                        app:tint="@color/v3_text_1" />
                </androidx.appcompat.widget.Toolbar>

                <!-- Loading indicator -->
                <ProgressBar
                    android:id="@+id/progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/v3_text_1"
                    android:visibility="invisible" />

            </com.google.android.material.appbar.CollapsingToolbarLayout>

            <!-- Pinned tab strip between header & paged content -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/v3_bg"
                app:tabGravity="fill"
                app:tabIndicatorColor="@color/v3_text_1"
                app:tabIndicatorFullWidth="false"
                app:tabMode="fixed"
                app:tabSelectedTextColor="@color/v3_text_1"
                app:tabTextColor="@color/v3_text_3" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Paged content: 插画 / 资料 -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/v3_bg"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    </com.scwang.smart.refresh.layout.SmartRefreshLayout>
</layout>
