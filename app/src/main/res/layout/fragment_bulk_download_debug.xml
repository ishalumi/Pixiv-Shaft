<?xml version="1.0" encoding="utf-8"?>
<!--
  批量下载 Debug 页:打开时自动扫一遍 app 所有可写位置 (内/外 cache, internal files,
  databases, MMKV, staging_dl 残留) 加 Room 表行数 + illustGson 总字节,在屏上打印一份
  diagnostic 报告。用来验证「3 GB 用户数据是不是批量下载漏掉的 staging 图片」之类的
  假设 —— 数据直接来自磁盘,不会撒谎。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/f5_to_deep_dark"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:fitsSystemWindows="true"
        app:navigationIcon="@drawable/ic_arrow_back_white_shadow"
        app:title="@string/debug_bulk_dl_entry"
        app:titleTextColor="@color/white" />

    <!--
      device fingerprint 行,点击复制完整 64 字符 hex。EventReporter.currentClientId()
      在 init 没跑完时会返回空串,这时显示占位文案,点击给 toast。仿照
      FragmentEventHistory 的 action_copy_client_id 入口语义。
    -->
    <LinearLayout
        android:id="@+id/fingerprintRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/event_history_copy_client_id"
            android:textColor="@color/v3_text_2"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/fingerprintText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:textColor="@color/v3_text_1"
            android:textIsSelectable="true"
            android:textSize="15sp"
            tools:text="abcdef0123456789..." />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/dividerHorizontal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/debug_bulk_dl_refresh" />

        <Button
            android:id="@+id/btnCopy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/debug_bulk_dl_copy" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/outputScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/outputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="14dp"
            android:textColor="@color/v3_text_1"
            android:textIsSelectable="true"
            android:textSize="14sp"
            tools:text="output appears here" />
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
