<?xml version="1.0" encoding="utf-8"?>
<!--
  批量选择 toolbar 单按钮：master-checkbox 模式。
  Icon 跟选中态切：
    - 还有未选项 → ic_select_all_24（点击全选）
    - 全部已选   → ic_deselect_24（点击取消全选）
  Fragment 在 refreshHeaderAndCta 里同步 setIcon + setTitle，所以 menu 里
  这个项的初始 icon/title 只是占位，运行时会被覆盖。
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <item
        android:id="@+id/action_select_toggle"
        android:icon="@drawable/ic_select_all_24"
        android:title="@string/bulk_select_select_all"
        app:showAsAction="always" />
</menu>
