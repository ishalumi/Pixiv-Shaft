<?xml version="1.0" encoding="utf-8"?>
<!-- 批量选择 cell 默认背景:14dp 圆角 v3_surface_2 占位色 + 1dp v3_border_2 描边,
     图未加载时给一个有定义的轮廓,跟 V3 风的 glass surface 一致。
     选中态由 selectedBorder 在外层另叠一圈 v3_blue stroke,所以这里只画底框。 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/v3_surface_2" />
    <stroke
        android:width="1dp"
        android:color="@color/v3_border_2" />
    <corners android:radius="14dp" />
</shape>
