<?xml version="1.0" encoding="utf-8"?>
<!--
  批量选择 cell 选中态边框:2.5dp ?attr/colorPrimary 描边,14dp 圆角(贴 thumb 的
  clipToOutline 14dp)。挂在 thumb container 之上的 sibling overlay View 而不是
  CardView 内部 child —— 这样 stroke 不会被 round clip 截断,圆角能完整跟 thumb
  圆角对齐。

  用 colorPrimary 跟随用户选的主题切色(这 app 有 10 多种主题)。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="2.5dp"
        android:color="?attr/colorPrimary" />
    <corners android:radius="14dp" />
</shape>
