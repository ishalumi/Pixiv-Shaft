<?xml version="1.0" encoding="utf-8"?>
<!--
  批量选择 cell 选中态边框 —— 障眼法:明显 inset 在 thumb 圆角里面,圆角小一档,
  眼睛不会再去比它跟 thumb 圆角对不对齐。
   - inset 2dp 用 <inset> drawable 实现,不动 selectedBorder View 的 layout
   - shape 圆角 12dp = 14 − 2,跟 inset 后位置的弧度对得上
   - 2.5dp stroke,?attr/colorPrimary 跟主题切色

  之前是 14dp 圆角描在 thumb 同一 bounds 上,Android 的 stroke 中心绘制 + 圆角
  outline clip 算法之间会差几个像素,肉眼看就是边框跟图角"贴不上"。inset 之后
  这道题直接绕过去了 —— stroke 明显在 thumb 圆角"里面",眼睛不会再去比。
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:inset="2dp">
    <shape android:shape="rectangle">
        <solid android:color="@android:color/transparent" />
        <stroke
            android:width="2.5dp"
            android:color="?attr/colorPrimary" />
        <corners android:radius="12dp" />
    </shape>
</inset>
