<?xml version="1.0" encoding="utf-8"?>
<!--
  Material Icons "file_upload" — 向上箭头 + 底部托盘横线，标准的"导出/上传"
  语义。

  ⚠️ fillColor 直接写 @color/v3_text_1 (day=#1A1A2E / night=#F4F4F8)，
  不走 android:tint。早期 tint=?attr/colorPrimary + fillColor=white 在
  低饱和主题（黄/粉/浅蓝）下跟白底融合看不见；改成 tint=v3_text_1 后仍然
  整体褪色 —— Toolbar 的 ActionMenuView 会把 menu icon 套一层 alpha
  filter（即使 iconTintList=null 也压不住），让本来 #1A1A2E 渲染成淡灰。
  把颜色直接焊死到 fillColor 后，drawable 不依赖 tint pipeline，alpha
  仍可能存在但起码颜色基底已经是高对比度。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="@color/v3_text_1"
        android:pathData="M9,16h6v-6h4l-7,-7 -7,7h4zM5,18h14v2H5z" />
</vector>
