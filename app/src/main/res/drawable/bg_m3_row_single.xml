<?xml version="1.0" encoding="utf-8"?>
<!-- MD3-E 设置页分段行背景（独行）：v3_menu_bg 实底 + v3_border_2 hairline（同 bg_v3_settings_card
     思路，浅色模式靠 hairline 从 #FAFAFA 背景浮出），四角 20dp。 -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?android:attr/colorControlHighlight">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/v3_menu_bg" />
            <corners android:radius="20dp" />
            <stroke
                android:width="0.5dp"
                android:color="@color/v3_border_2" />
        </shape>
    </item>
</ripple>
